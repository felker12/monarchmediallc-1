{
    "extends": "astro/tsconfigs/base",
    "compilerOptions": {
        "ignoreDeprecations": "6.0", //Ignore deprecation warnings for Astro 6.0
        "baseUrl": "src",
        "paths": {
            "@components/*": [
                "components/*"
            ],
            "@layouts/*": [
                "layouts/*"
            ],
            "@assets/*": [
                "assets/*"
            ],
            "@pages/*": [
                "pages/*"
            ],
            "@data/*": [
                "data/*"
            ]
        }
    }
}