---
import '../../src/styles/globals.css';
import '@fontsource-variable/inter/wght.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <!-- Faded page load-in -->
        <style>
            body {
                animation: fadeInAnimation ease 3s;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
            }
            @keyframes fadeInAnimation {
                0% {
                    opacity: 0;
                }

                100% {
                    opacity: 1;
                }
            }
        </style>
        <!-- Primary Meta Tags -->
        <title>Monarch Media LLC | Social Media, Marketing & Web Design</title>
        <meta name="title" content="Monarch Media LLC | Social Media, Marketing & Web Design" />
        <meta
            name="description"
            content="Stand out with bold web design, branding, and marketing services with Monarch Media LLC. Serving Terre Haute and the Wabash Valley."
        />
        <link rel="canonical" href="https://monarchmediallc.com" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://monarchmediallc.com" />
        <meta property="og:title" content="Monarch Media LLC | Social Media, Marketing & Web Design" />
        <meta
            property="og:description"
            content="Stand out with bold web design, branding, and marketing services with Monarch Media LLC. Serving Terre Haute and the Wabash Valley."
        />
        <meta property="og:image" content="/images/ogbanner.png" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content="https://monarchmediallc.com" />
        <meta property="twitter:title" content="Monarch Media LLC | Social Media, Marketing & Web Design" />
        <meta
            property="twitter:description"
            content="Stand out with bold web design, branding, and marketing services with Monarch Media LLC. Serving Terre Haute and the Wabash Valley."
        />
        <meta property="twitter:image" content="/images/ogbanner.png" />
        <meta
            name="keywords"
            content="marketing, web design, web designer, website design, website designer, social media, terre haute, marketing terre haute, web design terre haute, social media terre haute, branding, custom websites"
        />
        <meta name="robots" content="index, follow" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />

        <!-- GoatCounter -->
        <script is:inline data-goatcounter="https://monarchmediallc.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    </head>

    <body class="antialiased text-white entry-fade-in">
        <div class="relative min-h-[100svh] w-full bg-cover bg-center bg-blend-hard-light">
            <Header />

            <slot />

            <Footer />
        </div>
    </body>
</html>
