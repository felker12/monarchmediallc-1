---
import { Icon } from 'astro-icon/components';

const benefits = [
    {
        title: 'Custom development',
        icon: 'heroicons:code-bracket-square',
        description: 'Every project is built around your business instead of forcing your content into a generic page-builder template.'
    },
    {
        title: 'Performance focused',
        icon: 'heroicons:bolt',
        description: 'Responsive layouts, optimized media, and modern delivery practices help keep your website fast and dependable.'
    },
    {
        title: 'SEO foundations',
        icon: 'heroicons:magnifying-glass',
        description: 'Technical structure, metadata, semantic markup, and local-search fundamentals are considered from the beginning.'
    },
    {
        title: 'Built to grow',
        icon: 'heroicons:arrow-trending-up',
        description: 'Your website can evolve from a focused marketing presence into dynamic content, integrations, portals, and custom software.'
    },
    {
        title: 'Direct collaboration',
        icon: 'heroicons:users',
        description: 'You work with the people designing and developing your solution rather than being passed between disconnected teams.'
    },
    {
        title: 'Long-term support',
        icon: 'heroicons:shield-check',
        description: 'Monarch Care plans provide technical maintenance, content updates, analytics, and ongoing improvements after launch.'
    }
] as const;
---

<section aria-labelledby="why-monarch-heading">
    <header class="mx-auto max-w-3xl text-center">
        <p class="font-body text-xs font-bold uppercase tracking-[0.25em] text-header">The Monarch difference</p>

        <h2 id="why-monarch-heading" class="mt-4 font-header text-4xl text-white sm:text-5xl">More than another website template</h2>

        <p class="mt-5 font-body text-base leading-7 text-white/60">
            Monarch combines design, performance, and software engineering to create websites that support real business goals.
        </p>
    </header>

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
            benefits.map((benefit) => (
                <article
                    class="group rounded-2xl border border-white/10
                        bg-[#0c0c0e]/70 p-6
                        transition-all duration-300
                        hover:-translate-y-1
                        hover:border-primary/35
                        hover:shadow-[0_18px_45px_rgba(69,26,107,0.14)]"
                >
                    <div
                        class="flex h-10 w-10 items-center justify-center
                            rounded-full border border-primary/30
                            bg-primary/15 text-header
                            transition-all duration-300
                            group-hover:scale-110
                            group-hover:border-complementary/60
                            group-hover:bg-complementary/15
                            group-hover:text-complementary"
                    >
                        <Icon
                            name={benefit.icon}
                            class="h-5 w-5 transition-transform duration-300
                                group-hover:scale-110"
                        />
                    </div>

                    <h3
                        class="mt-5 font-subheader text-xl text-white
                            transition-colors duration-300
                            group-hover:text-header"
                    >
                        {benefit.title}
                    </h3>

                    <p
                        class="mt-3 font-body text-sm leading-6 text-white/55
                            transition-colors duration-300
                            group-hover:text-white/70"
                    >
                        {benefit.description}
                    </p>
                </article>
            ))
        }
    </div>
</section>
