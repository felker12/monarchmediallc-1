---
import { Icon } from 'astro-icon/components';

const steps = [
    {
        title: 'Discovery',
        description: 'We learn about your business, goals, audience, content, and current challenges before defining the right solution.'
    },
    {
        title: 'Design',
        description: 'We shape the page structure, visual direction, messaging hierarchy, and user experience before development begins.'
    },
    {
        title: 'Build',
        description: 'Using modern frameworks and clean architecture, we develop a fast, accessible, and maintainable digital experience.'
    },
    {
        title: 'Launch',
        description: 'We complete testing, configure hosting and analytics, and carefully deploy your website with minimal disruption.'
    },
    {
        title: 'Growth',
        description: 'After launch, Monarch Care can provide maintenance, content updates, analytics, optimization, and future development.'
    }
] as const;
---

<section aria-labelledby="process-heading" class="py-20">
    <header class="mx-auto max-w-3xl text-center">
        <p class="font-body text-xs font-semibold uppercase tracking-[0.25em] text-header">From idea to long-term support</p>
        <h2 id="process-heading" class="mt-4 font-header text-4xl text-white sm:text-5xl">Our Process</h2>
        <p class="mt-5 font-body text-base leading-7 text-white/60">
            Every successful project follows a clear roadmap—from the first conversation to launch and continued growth.
        </p>
    </header>

    <div class="mt-12 rounded-3xl border border-primary/30 bg-white/[0.035] px-6 py-12 sm:px-8 xl:px-10">
        <ol class="flex flex-col items-center justify-center gap-x-4 gap-y-10 md:flex-row md:flex-wrap md:items-start md:gap-y-16">
            {
                steps.map((step, index) => (
                    <li class="group flex flex-col items-center md:flex-row md:items-start gap-4 md:gap-2">
                        {/* Step Circle & Description */}
                        <div class="flex flex-col items-center text-center w-[180px]">
                            <div
                                class="flex h-24 w-24 items-center justify-center 
                                    rounded-full border-2 border-primary
                                    bg-white/[0.025] transition-all duration-300 
                                    group-hover:-translate-y-1 group-hover:border-complementary 
                                    group-hover:bg-primary/15 
                                    group-hover:shadow-[0_12px_28px_rgba(155,93,229,0.25)]"
                            >
                                <span class="font-body text-xs font-bold text-white tracking-wider">{step.title}</span>
                            </div>
                            <p class="mt-5 font-body text-xs leading-6 text-white/60 transition-colors duration-300 group-hover:text-white/80">
                                {step.description}
                            </p>
                        </div>

                        {/* Responsive Connector Arrows */}
                        {index < steps.length - 1 && (
                            <div
                                aria-hidden="true"
                                class="flex shrink-0 items-center justify-center pt-2 text-primary
                                    transition-all duration-300
                                    group-hover:translate-y-1 group-hover:text-complementary
                                    md:pt-9 md:group-hover:translate-x-1 md:group-hover:translate-y-0"
                            >
                                <Icon name="heroicons:arrow-right" class="h-6 w-6 rotate-90 md:rotate-0" />
                            </div>
                        )}
                    </li>
                ))
            }
        </ol>
    </div>
</section>
