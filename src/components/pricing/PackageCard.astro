---
import { Icon } from 'astro-icon/components';
import type { ServicePackage } from '@data/ServicePackages';
import { formatServicePackagePrice } from '@data/ServicePackages';

interface Props {
    servicePackage: ServicePackage;
}

const { servicePackage } = Astro.props;

const packageClasses: Record<ServicePackage['packageLevel'], string> = {
    Core: 'border-white/10',
    Professional: 'border-header/60 shadow-[0_0_45px_rgba(232,207,124,0.1)] xl:-translate-y-3',
    Premium: 'border-complementary/55',
    Bespoke: 'border-primary/70'
};

const highlights = servicePackage.features.slice(0, 4);
---

<article
    class:list={[
        'relative flex h-full flex-col rounded-2xl border bg-[#0c0c0e]/90 p-6 backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:border-header/40',
        packageClasses[servicePackage.packageLevel]
    ]}
>
    {
        servicePackage.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full border border-white/10 bg-gradient-to-r from-complementary to-primary px-4 py-1 font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white">
                Most popular
            </span>
        )
    }

    <header>
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.22em] text-complementary">
            {servicePackage.packageLevel}
        </p>

        <h2 class="mt-2 font-header text-3xl text-white">
            {servicePackage.name}
        </h2>

        <p class="mt-2 min-h-12 font-body text-sm italic leading-6 text-white/50">
            {servicePackage.tagline}
        </p>

        <div class="mt-5 border-y border-white/5 py-4">
            <p class="font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white/35">Investment</p>

            <p class="mt-1 font-header text-3xl text-white">
                {formatServicePackagePrice(servicePackage)}
            </p>
        </div>
    </header>

    <section class="mt-5">
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white/35">Best for</p>

        <p class="mt-2 line-clamp-3 font-body text-sm leading-6 text-white/70">
            {servicePackage.idealFor}
        </p>
    </section>

    <section class="mt-6 flex-1">
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white/35">Package highlights</p>

        <ul class="mt-3 space-y-3">
            {
                highlights.map((feature) => (
                    <li class="flex gap-3 font-body text-sm leading-6 text-white/65">
                        <Icon name="heroicons:check" class="mt-1 h-4 w-4 shrink-0 text-complementary" />

                        <span>{feature}</span>
                    </li>
                ))
            }
        </ul>
    </section>

    <div class="mt-7 grid gap-3">
        <a
            href={`/contact?package=${servicePackage.id}`}
            class:list={[
                'btn w-full rounded-lg py-3 font-body text-xs uppercase tracking-[0.16em]',
                servicePackage.featured ? 'bg-primary text-white hover:bg-primary/85' : 'border border-white/10 bg-white/[0.035] hover:bg-white/[0.08]'
            ]}
        >
            {servicePackage.ctaLabel}
        </a>

        <a href="#package-comparison" class="text-center font-body text-xs font-semibold text-white/45 transition hover:text-header">
            Compare full package details
        </a>
    </div>
</article>
