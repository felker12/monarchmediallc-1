---
// src/components/AdminNavBar.astro
import { publicItems, adminItems } from '@data/NavData';
import { Icon } from 'astro-icon/components';

const currentPath = Astro.url.pathname;

const isCurrentPageAdmin = currentPath.startsWith('/admin') && currentPath !== '/admin/login';

const isContactActive = currentPath === '/contact' || currentPath.startsWith('/contact/');

const getLinkClass = (href: string) => {
    const isCurrent = href === '/' ? currentPath === '/' : currentPath.startsWith(href);

    return isCurrent
        ? 'text-white bg-white/10 shadow-[inset_0_0_12px_rgba(255,255,255,0.05)] border-t border-white/5 font-semibold'
        : 'text-gray-400 hover:text-white hover:bg-white/5 active:bg-white/10';
};
---

<nav class="flex items-center gap-4 sm:gap-6 relative">
    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-1 sm:gap-2 font-body text-sm font-medium tracking-wide">
        {
            publicItems.map((item) => (
                <li>
                    <a href={item.href} class={`inline-block px-3 py-2 rounded-lg transition-all duration-200 ${getLinkClass(item.href)}`}>
                        {item.linkText}
                    </a>
                </li>
            ))
        }

        <!-- Management Dropdown -->
        <li class="relative group py-2">
            <button
                type="button"
                class={`flex items-center gap-1.5 px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer ${
                    isCurrentPageAdmin ? 'text-white bg-white/10 font-semibold' : 'text-gray-400 group-hover:text-white'
                }`}
            >
                Management

                <Icon
                    name="heroicons:chevron-down-20-solid"
                    class="w-5 h-5 opacity-60 group-hover:opacity-100 transition-transform duration-200 group-hover:rotate-180"
                />
            </button>

            <div
                class="absolute left-0 top-full mt-1 w-48
                    bg-[#121214]/95 border border-white/5 rounded-xl
                    shadow-2xl p-1.5 opacity-0 invisible
                    group-hover:opacity-100 group-hover:visible
                    transition-all duration-200 scale-95
                    group-hover:scale-100 z-50 origin-top-left
                    backdrop-blur-md"
            >
                {
                    adminItems.map((item) => (
                        <a href={item.href} class={`block px-3 py-2 text-xs rounded-lg transition-all duration-150 ${getLinkClass(item.href)}`}>
                            {item.linkText}
                        </a>
                    ))
                }

                <div class="mt-1.5 pt-1.5 border-t border-white/5">
                    <a
                        href="/api/admin/logout"
                        class="flex items-center gap-2 px-3 py-2 text-xs font-semibold
                            text-red-400 hover:text-red-300
                            hover:bg-red-500/5 rounded-lg
                            transition-all duration-150"
                    >
                        <Icon name="heroicons:arrow-right-on-rectangle" class="w-4 h-4" />

                        Logout
                    </a>
                </div>
            </div>
        </li>
    </ul>

    <!-- Contact CTA -->
    <div class="hidden md:block">
        <a
            href="/contact"
            class={`relative inline-flex items-center justify-center font-body
                text-xs font-bold uppercase tracking-[0.15em] px-5 py-2.5
                rounded-xl border transition-all duration-300 group overflow-hidden
                ${
                    isContactActive
                        ? 'border-complementary bg-[#0c0c0e]/90 text-white shadow-[0_4px_25px_rgba(136,69,124,0.35)]'
                        : 'border-white/10 bg-[#0c0c0e]/60 text-white/90 hover:border-complementary/50 hover:shadow-[0_4px_25px_rgba(136,69,124,0.25)] backdrop-blur-md shadow-[0_4px_20px_rgba(0,0,0,0.35)] hover:text-white'
                }`}
        >
            <span
                class={`absolute top-0 h-[1.5px]
                    bg-gradient-to-r from-transparent via-complementary to-transparent
                    transition-all duration-300
                    ${
                        isContactActive
                            ? 'left-1 right-1 via-complementary'
                            : 'left-3 right-3 via-complementary/60 group-hover:left-1 group-hover:right-1 group-hover:via-complementary'
                    }`}></span>

            <span
                class={`absolute inset-0 bg-gradient-to-b
                    from-primary/15 to-transparent transition-opacity duration-300
                    ${isContactActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}></span>

            <span class="relative z-10"> Get in touch </span>
        </a>
    </div>

    <!-- Mobile Toggle -->
    <button
        id="admin-menu-toggle"
        type="button"
        class="md:hidden p-2 text-gray-400 hover:text-white focus:outline-none transition-colors"
        aria-label="Toggle menu"
        aria-controls="admin-mobile-menu"
        aria-expanded="false"
    >
        <Icon name="heroicons:bars-3" class="w-6 h-6" />
    </button>

    <!-- Mobile Menu -->
    <div
        id="admin-mobile-menu"
        class="absolute right-0 top-full mt-2 w-52
            bg-[#121214]/95 border border-white/5 rounded-xl
            shadow-2xl p-2 opacity-0 invisible scale-95
            transition-all duration-200 z-50 origin-top-right
            backdrop-blur-md md:hidden"
    >
        <ul class="space-y-1 font-body text-sm font-medium">
            <li class="text-[10px] uppercase font-bold text-gray-500 tracking-wider px-3 py-1">Public Views</li>

            {
                publicItems.map((item) => (
                    <li>
                        <a href={item.href} class={`block px-3 py-2 rounded-lg text-sm transition-all ${getLinkClass(item.href)}`}>
                            {item.linkText}
                        </a>
                    </li>
                ))
            }

            <li class="pt-2 mt-2 border-t border-white/5">
                <a
                    href="/contact"
                    class={`relative block text-center font-body text-xs font-bold
                        uppercase tracking-[0.12em] py-2.5 px-3 rounded-lg
                        border transition-all duration-300 overflow-hidden group
                        ${
                            isContactActive
                                ? 'border-complementary bg-[#0c0c0e] text-white shadow-[0_4px_15px_rgba(136,69,124,0.2)]'
                                : 'border-white/10 bg-[#0c0c0e]/80 text-white/90'
                        }`}
                >
                    <span
                        class={`absolute top-0 h-[1.5px]
                            bg-gradient-to-r from-transparent via-complementary to-transparent
                            transition-all duration-300
                            ${isContactActive ? 'left-1 right-1 via-complementary' : 'left-4 right-4 via-complementary/60'}`}></span>

                    Get in touch
                </a>
            </li>

            <li class="text-[10px] uppercase font-bold text-gray-500 tracking-wider px-3 pt-3 pb-1 border-t border-white/5 mt-2">Management</li>

            {
                adminItems.map((item) => (
                    <li>
                        <a href={item.href} class={`block px-3 py-2 rounded-lg text-sm transition-all ${getLinkClass(item.href)}`}>
                            {item.linkText}
                        </a>
                    </li>
                ))
            }

            <li class="pt-2 mt-2 border-t border-white/5">
                <a
                    href="/api/admin/logout"
                    class="flex items-center gap-2 w-full font-semibold text-sm
                        text-red-400 hover:text-red-300 hover:bg-red-500/5
                        px-3 py-2 rounded-lg transition-all"
                >
                    <Icon name="heroicons:arrow-right-on-rectangle" class="w-4 h-4" />

                    Logout
                </a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const toggleButton = document.getElementById('admin-menu-toggle');

    const mobileMenu = document.getElementById('admin-mobile-menu');

    const setMobileMenuState = (isOpen: boolean) => {
        if (!toggleButton || !mobileMenu) {
            return;
        }

        toggleButton.setAttribute('aria-expanded', String(isOpen));

        mobileMenu.classList.toggle('opacity-0', !isOpen);
        mobileMenu.classList.toggle('invisible', !isOpen);
        mobileMenu.classList.toggle('scale-95', !isOpen);
    };

    if (toggleButton && mobileMenu) {
        toggleButton.addEventListener('click', (event) => {
            event.stopPropagation();

            const isCurrentlyOpen = toggleButton.getAttribute('aria-expanded') === 'true';

            setMobileMenuState(!isCurrentlyOpen);
        });

        document.addEventListener('click', (event) => {
            const target = event.target;

            if (!(target instanceof Node)) {
                return;
            }

            if (!mobileMenu.contains(target) && !toggleButton.contains(target)) {
                setMobileMenuState(false);
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                setMobileMenuState(false);
                toggleButton.focus();
            }
        });
    }
</script>
