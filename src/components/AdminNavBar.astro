---
// src/components/AdminNavBar.astro
import { publicItems, adminItems } from '@data/NavData';
import { Icon } from 'astro-icon/components';

const currentPath = Astro.url.pathname;

const isCurrentPage = (href: string) => (href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(`${href}/`));

const isCurrentPageAdmin = currentPath.startsWith('/admin') && currentPath !== '/admin/login';
const isContactActive = isCurrentPage('/contact');

const getLinkClass = (href: string) =>
    isCurrentPage(href)
        ? 'text-white bg-white/10 shadow-[inset_0_0_12px_rgba(255,255,255,0.05)] border-t border-white/5 font-semibold'
        : 'text-gray-400 hover:text-white hover:bg-white/5 active:bg-white/10';
---

<nav class="relative flex items-center gap-4 sm:gap-6" aria-label="Administrative navigation">
    <!-- Desktop Navigation -->
    <ul class="hidden items-center gap-1 font-body text-sm font-medium tracking-wide md:flex sm:gap-2">
        {
            publicItems.map((item) => (
                <li>
                    <a
                        href={item.href}
                        aria-current={isCurrentPage(item.href) ? 'page' : undefined}
                        class={`inline-block rounded-lg px-3 py-2 transition-all duration-200 ${getLinkClass(item.href)}`}
                    >
                        {item.linkText}
                    </a>
                </li>
            ))
        }

        <!-- Management Dropdown -->
        <li>
            <details class="group relative py-2">
                <summary
                    class={`flex cursor-pointer list-none items-center gap-1.5 rounded-lg px-3 py-2 transition-all duration-200 marker:content-none [&::-webkit-details-marker]:hidden ${
                        isCurrentPageAdmin ? 'bg-white/10 font-semibold text-white' : 'text-gray-400 hover:bg-white/5 hover:text-white'
                    }`}
                >
                    Management

                    <Icon
                        name="heroicons:chevron-down-20-solid"
                        class="h-5 w-5 opacity-60 transition-transform duration-200 group-open:rotate-180 group-open:opacity-100"
                        aria-hidden="true"
                    />
                </summary>

                <div
                    class="invisible absolute left-0 top-full z-50 mt-1 w-48 origin-top-left scale-95 rounded-xl border border-white/5 bg-[#121214]/95 p-1.5 opacity-0 shadow-2xl backdrop-blur-md transition-[opacity,transform,visibility] duration-200 group-open:visible group-open:scale-100 group-open:opacity-100 group-focus-within:visible group-focus-within:scale-100 group-focus-within:opacity-100"
                >
                    {
                        adminItems.map((item) => (
                            <a
                                href={item.href}
                                aria-current={isCurrentPage(item.href) ? 'page' : undefined}
                                class={`block rounded-lg px-3 py-2 text-xs transition-all duration-150 ${getLinkClass(item.href)}`}
                            >
                                {item.linkText}
                            </a>
                        ))
                    }

                    <div class="mt-1.5 border-t border-white/5 pt-1.5">
                        <a
                            href="/api/admin/logout"
                            class="flex items-center gap-2 rounded-lg px-3 py-2 text-xs font-semibold text-red-400 transition-all duration-150 hover:bg-red-500/5 hover:text-red-300"
                        >
                            <Icon name="heroicons:arrow-right-on-rectangle" class="h-4 w-4" aria-hidden="true" />
                            Logout
                        </a>
                    </div>
                </div>
            </details>
        </li>
    </ul>

    <!-- Desktop Contact CTA -->
    <div class="hidden md:block">
        <a
            href="/contact"
            aria-current={isContactActive ? 'page' : undefined}
            class={`group relative inline-flex items-center justify-center overflow-hidden rounded-xl border px-5 py-2.5 font-body text-xs font-bold uppercase tracking-[0.15em] transition-all duration-300 ${
                isContactActive
                    ? 'border-complementary bg-[#0c0c0e]/90 text-white shadow-[0_4px_25px_rgba(136,69,124,0.35)]'
                    : 'border-white/10 bg-[#0c0c0e]/60 text-white/90 shadow-[0_4px_20px_rgba(0,0,0,0.35)] backdrop-blur-md hover:border-complementary/50 hover:text-white hover:shadow-[0_4px_25px_rgba(136,69,124,0.25)]'
            }`}
        >
            <span
                aria-hidden="true"
                class={`absolute top-0 h-[1.5px] bg-gradient-to-r from-transparent via-complementary to-transparent transition-all duration-300 ${
                    isContactActive
                        ? 'left-1 right-1 via-complementary'
                        : 'left-3 right-3 via-complementary/60 group-hover:left-1 group-hover:right-1 group-hover:via-complementary'
                }`}></span>

            <span
                aria-hidden="true"
                class={`absolute inset-0 bg-gradient-to-b from-primary/15 to-transparent transition-opacity duration-300 ${
                    isContactActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'
                }`}></span>

            <span class="relative z-10">Get in touch</span>
        </a>
    </div>

    <!-- Mobile Toggle -->
    <button
        id="admin-menu-toggle"
        type="button"
        class="relative flex h-10 w-10 items-center justify-center rounded-xl border border-transparent text-gray-400 transition-all duration-200 hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-complementary/60 active:scale-95 md:hidden"
        aria-label="Open menu"
        aria-controls="admin-mobile-menu"
        aria-expanded="false"
    >
        <Icon
            name="heroicons:bars-3"
            class="menu-open-icon absolute h-6 w-6 rotate-0 scale-100 opacity-100 transition-[opacity,transform] duration-200"
            aria-hidden="true"
        />

        <Icon
            name="heroicons:x-mark"
            class="menu-close-icon absolute h-6 w-6 -rotate-90 scale-75 opacity-0 transition-[opacity,transform] duration-200"
            aria-hidden="true"
        />
    </button>

    <!-- Mobile Menu -->
    <div
        id="admin-mobile-menu"
        class="invisible absolute right-0 top-full z-50 mt-2 w-52 origin-top-right scale-95 rounded-xl border border-white/5 bg-[#121214]/95 p-2 opacity-0 shadow-2xl backdrop-blur-md transition-[opacity,transform,visibility] duration-200 md:hidden"
    >
        <ul class="space-y-1 font-body text-sm font-medium">
            <li class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-gray-500">Public Views</li>

            {
                publicItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            aria-current={isCurrentPage(item.href) ? 'page' : undefined}
                            class={`mobile-nav-link block rounded-lg px-3 py-2 text-sm transition-all duration-200 ${getLinkClass(item.href)}`}
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))
            }

            <li class="mt-2 border-t border-white/5 pt-2">
                <a
                    href="/contact"
                    aria-current={isContactActive ? 'page' : undefined}
                    class={`mobile-nav-link group relative block overflow-hidden rounded-lg border px-3 py-2.5 text-center font-body text-xs font-bold uppercase tracking-[0.12em] transition-all duration-300 ${
                        isContactActive
                            ? 'border-complementary bg-[#0c0c0e] text-white shadow-[0_4px_15px_rgba(136,69,124,0.2)]'
                            : 'border-white/10 bg-[#0c0c0e]/80 text-white/90 hover:border-complementary/40 hover:text-white'
                    }`}
                >
                    <span
                        aria-hidden="true"
                        class={`absolute top-0 h-[1.5px] bg-gradient-to-r from-transparent via-complementary to-transparent transition-all duration-300 ${
                            isContactActive ? 'left-1 right-1 via-complementary' : 'left-4 right-4 via-complementary/60 group-hover:left-1 group-hover:right-1'
                        }`}></span>

                    <span class="relative z-10">Get in touch</span>
                </a>
            </li>

            <li class="mt-2 border-t border-white/5 px-3 pb-1 pt-3 text-[10px] font-bold uppercase tracking-wider text-gray-500">Management</li>

            {
                adminItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            aria-current={isCurrentPage(item.href) ? 'page' : undefined}
                            class={`mobile-nav-link block rounded-lg px-3 py-2 text-sm transition-all duration-200 ${getLinkClass(item.href)}`}
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))
            }

            <li class="mt-2 border-t border-white/5 pt-2">
                <a
                    href="/api/admin/logout"
                    class="mobile-nav-link flex w-full items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold text-red-400 transition-all duration-200 hover:bg-red-500/5 hover:text-red-300"
                >
                    <Icon name="heroicons:arrow-right-on-rectangle" class="h-4 w-4" aria-hidden="true" />
                    Logout
                </a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const toggleButton = document.getElementById('admin-menu-toggle');
    const mobileMenu = document.getElementById('admin-mobile-menu');
    const openIcon = toggleButton?.querySelector('.menu-open-icon');
    const closeIcon = toggleButton?.querySelector('.menu-close-icon');

    const setMobileMenuState = (isOpen: boolean) => {
        if (!toggleButton || !mobileMenu) return;

        toggleButton.setAttribute('aria-expanded', String(isOpen));
        toggleButton.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');

        toggleButton.classList.toggle('bg-white/5', isOpen);
        toggleButton.classList.toggle('border-white/10', isOpen);
        toggleButton.classList.toggle('text-white', isOpen);

        mobileMenu.classList.toggle('opacity-0', !isOpen);
        mobileMenu.classList.toggle('invisible', !isOpen);
        mobileMenu.classList.toggle('scale-95', !isOpen);

        openIcon?.classList.toggle('opacity-0', isOpen);
        openIcon?.classList.toggle('rotate-180', isOpen);
        openIcon?.classList.toggle('scale-75', isOpen);
        openIcon?.classList.toggle('opacity-100', !isOpen);
        openIcon?.classList.toggle('rotate-0', !isOpen);
        openIcon?.classList.toggle('scale-100', !isOpen);

        closeIcon?.classList.toggle('opacity-100', isOpen);
        closeIcon?.classList.toggle('rotate-0', isOpen);
        closeIcon?.classList.toggle('scale-100', isOpen);
        closeIcon?.classList.toggle('opacity-0', !isOpen);
        closeIcon?.classList.toggle('-rotate-90', !isOpen);
        closeIcon?.classList.toggle('scale-75', !isOpen);
    };

    if (toggleButton && mobileMenu) {
        toggleButton.addEventListener('click', (event) => {
            event.stopPropagation();
            const isOpen = toggleButton.getAttribute('aria-expanded') === 'true';
            setMobileMenuState(!isOpen);
        });

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
            link.addEventListener('click', () => setMobileMenuState(false));
        });

        document.addEventListener('click', (event) => {
            const target = event.target;

            if (target instanceof Node && !mobileMenu.contains(target) && !toggleButton.contains(target)) {
                setMobileMenuState(false);
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && toggleButton.getAttribute('aria-expanded') === 'true') {
                setMobileMenuState(false);
                toggleButton.focus();
            }
        });
    }
</script>
