---
// src/components/ContactForm.astro

interface Props {
    selectedService?: string;
    selectedPackage?: string;
    selectedCarePlan?: string;
}

const { selectedService = '', selectedPackage = '', selectedCarePlan = '' } = Astro.props;

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;

/**
 * Converts identifiers such as:
 * "premium"          -> "Premium"
 * "bespoke-support"  -> "Bespoke Support"
 */
const formatSelectionName = (value: string) =>
    value
        .split('-')
        .filter(Boolean)
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ');

const selectedPackageName = selectedPackage ? `${formatSelectionName(selectedPackage)} Website Package` : '';

const selectedCarePlanName = selectedCarePlan ? `${formatSelectionName(selectedCarePlan)} Care Plan` : '';

const selectedSummary = selectedPackageName || selectedCarePlanName;

const selectionType = selectedPackage ? 'Website package' : selectedCarePlan ? 'Monarch Care plan' : '';

/*
 * Keep the broad service category aligned with the link that brought
 * the visitor to the form.
 */
const selectedInterest = selectedCarePlan
    ? 'care-plan'
    : selectedPackage
      ? 'custom-website'
      : selectedService === 'website'
        ? 'custom-website'
        : selectedService || 'custom-website';

const submissionSubject = selectedPackageName
    ? `New website package inquiry: ${selectedPackageName}`
    : selectedCarePlanName
      ? `New Monarch Care inquiry: ${selectedCarePlanName}`
      : 'New Monarch Media inquiry';
---

<form id="waitlist-form" class="space-y-6" novalidate>
    <!-- Web3Forms configuration -->
    <input type="hidden" name="access_key" value={web3formsKey} />

    <input type="hidden" name="subject" value={submissionSubject} />

    {selectedPackageName && <input type="hidden" name="Selected Package" value={selectedPackageName} />}

    {selectedCarePlanName && <input type="hidden" name="Selected Care Plan" value={selectedCarePlanName} />}

    <!-- Silent honeypot -->
    <input type="checkbox" class="hidden" style="display:none" name="botcheck" tabindex="-1" autocomplete="off" />

    <!-- Selected package or care-plan context -->
    {
        selectedSummary && (
            <aside
                class="relative overflow-hidden rounded-xl border
                    border-complementary/20 bg-complementary/5 px-4 py-4"
                aria-label="Selected inquiry option"
            >
                <div
                    aria-hidden="true"
                    class="absolute inset-y-0 left-0 w-[2px]
                        bg-gradient-to-b from-transparent
                        via-complementary to-transparent"
                />

                <p
                    class="font-body text-[10px] font-bold uppercase
                        tracking-[0.18em] text-complementary"
                >
                    You're inquiring about
                </p>

                <p class="mt-1 font-body text-base font-semibold text-white">{selectedSummary}</p>

                <p class="mt-1 font-body text-xs leading-5 text-white/50">
                    {selectionType} selected from our service options. You can change the broader service category below if your needs have changed.
                </p>
            </aside>
        )
    }

    <!-- Full name -->
    <div class="space-y-2">
        <label for="name" class="block font-body text-xs font-bold uppercase
                tracking-wider text-white/70">
            Full Name
            <span class="text-red-400">*</span>
        </label>

        <input
            type="text"
            name="name"
            id="name"
            required
            autocomplete="name"
            class="w-full rounded-xl border border-white/10
                bg-white/[0.03] px-4 py-3
                font-body text-sm text-white
                placeholder:text-white/25
                outline-none transition-all
                focus:border-complementary
                focus:bg-white/[0.05]
                focus:ring-1 focus:ring-complementary"
            placeholder="John Doe"
        />

        <div class="empty-feedback mt-1 text-xs text-red-400">Please provide your full name so we know who to address.</div>
    </div>

    <!-- Email and organization -->
    <div class="grid gap-6 sm:grid-cols-2">
        <div class="space-y-2">
            <label for="email" class="block font-body text-xs font-bold uppercase
                    tracking-wider text-white/70">
                Email address
                <span class="text-red-400">*</span>
            </label>

            <input
                type="email"
                name="email"
                id="email"
                required
                autocomplete="email"
                class="w-full rounded-xl border border-white/10
                    bg-white/[0.03] px-4 py-3
                    font-body text-sm text-white
                    placeholder:text-white/25
                    outline-none transition-all
                    focus:border-complementary
                    focus:bg-white/[0.05]
                    focus:ring-1 focus:ring-complementary"
                placeholder="you@example.com"
            />

            <div class="empty-feedback mt-1 text-xs text-red-400">Please provide your email address.</div>

            <div class="invalid-feedback mt-1 text-xs text-red-400">Please provide a valid email address.</div>
        </div>

        <div class="space-y-2">
            <label for="company" class="block font-body text-xs font-bold uppercase
                    tracking-wider text-white/70">
                Company / Org

                <span class="text-[10px] font-normal normal-case text-white/40"> (Optional) </span>
            </label>

            <input
                type="text"
                name="company"
                id="company"
                autocomplete="organization"
                class="w-full rounded-xl border border-white/10
                    bg-white/[0.03] px-4 py-3
                    font-body text-sm text-white
                    placeholder:text-white/25
                    outline-none transition-all
                    focus:border-complementary
                    focus:bg-white/[0.05]
                    focus:ring-1 focus:ring-complementary"
                placeholder="Acme Corp"
            />
        </div>
    </div>

    <!-- Broad service category -->
    <div class="space-y-2">
        <label for="interest" class="block font-body text-xs font-bold uppercase
                tracking-wider text-white/70">
            What service are you most interested in?
        </label>

        <select
            name="interest"
            id="interest"
            class="w-full rounded-xl border border-white/10
                bg-[#121214] px-4 py-3
                font-body text-sm text-white/80
                outline-none transition-all
                focus:border-complementary
                focus:ring-1 focus:ring-complementary"
        >
            <option value="custom-website" selected={selectedInterest === 'custom-website'}> Custom Web Development & Design </option>

            <option value="care-plan" selected={selectedInterest === 'care-plan'}> Monarch Care Plan (Hosting & Maintenance) </option>

            <option value="full-scope" selected={selectedInterest === 'full-scope'}> Bespoke Enterprise Software / Portal </option>

            <option value="other" selected={selectedInterest === 'other'}> Other / General Consultation </option>
        </select>
    </div>

    <!-- Message -->
    <div class="space-y-2">
        <label for="message" class="block font-body text-xs font-bold uppercase
                tracking-wider text-white/70">
            Project goals & timeline
            <span class="text-red-400">*</span>
        </label>

        <textarea
            name="message"
            id="message"
            rows="4"
            required
            class="w-full resize-none rounded-xl
                border border-white/10 bg-white/[0.03]
                px-4 py-3 font-body text-sm text-white
                placeholder:text-white/25
                outline-none transition-all
                focus:border-complementary
                focus:bg-white/[0.05]
                focus:ring-1 focus:ring-complementary"
            placeholder="Tell us about your project goals, required launch timelines, or any details that will help us understand your needs..."></textarea>

        <div class="empty-feedback mt-1 text-xs text-red-400">Please enter your project goals.</div>
    </div>

    <!-- Submit -->
    <div class="pt-2">
        <button
            type="submit"
            class="inline-flex w-full cursor-pointer items-center
                justify-center rounded-xl border border-white/10
                bg-primary py-4
                font-body text-xs font-bold uppercase
                tracking-[0.2em] text-white
                shadow-[0_4px_15px_rgba(69,26,107,0.3)]
                transition-all duration-200
                hover:scale-[1.01] hover:bg-primary/90
                hover:shadow-[0_4px_25px_rgba(69,26,107,0.45)]
                active:scale-[0.99]
                disabled:cursor-not-allowed
                disabled:opacity-60
                disabled:hover:scale-100"
        >
            Apply for early access
        </button>
    </div>

    <div id="result" class="mt-3 text-center font-body text-sm
            transition-all duration-300" aria-live="polite"></div>
</form>

<style>
    .invalid-feedback,
    .empty-feedback {
        display: none;
    }

    .was-validated :placeholder-shown:invalid ~ .empty-feedback {
        display: block;
    }

    .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
        display: block;
    }

    .was-validated :invalid {
        border-color: rgba(239, 68, 68, 0.4);
    }
</style>

<script is:inline>
    const form = document.getElementById('waitlist-form');
    const result = document.getElementById('result');

    if (form instanceof HTMLFormElement && result instanceof HTMLDivElement) {
        const submitButton = form.querySelector('button[type="submit"]');

        const setSubmitting = (isSubmitting) => {
            if (!(submitButton instanceof HTMLButtonElement)) {
                return;
            }

            submitButton.disabled = isSubmitting;
            submitButton.textContent = isSubmitting ? 'Submitting...' : 'Apply for early access';
        };

        const showResult = (message, type) => {
            result.classList.remove('text-white/60', 'text-red-400', 'text-green-400');

            if (type === 'success') {
                result.classList.add('text-green-400');
            } else if (type === 'error') {
                result.classList.add('text-red-400');
            } else {
                result.classList.add('text-white/60');
            }

            result.textContent = message;
        };

        form.addEventListener('submit', async (event) => {
            event.preventDefault();

            form.classList.add('was-validated');

            if (!form.checkValidity()) {
                const firstInvalidField = form.querySelector(':invalid');

                if (firstInvalidField instanceof HTMLElement) {
                    firstInvalidField.focus();
                }

                return;
            }

            setSubmitting(true);
            showResult('Submitting application...', 'pending');

            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());

            if (!payload.botcheck) {
                payload.botcheck = '';
            }

            try {
                const response = await fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        Accept: 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const responseData = await response.json();

                if (!response.ok) {
                    showResult(responseData.message || 'An error occurred during submission.', 'error');

                    return;
                }

                showResult("Application received! We'll reach out soon.", 'success');

                form.reset();
                form.classList.remove('was-validated');

                setTimeout(() => {
                    result.textContent = '';
                }, 6000);
            } catch (error) {
                console.error('Contact form submission failed:', error);

                showResult('Something went wrong. Please try again later.', 'error');
            } finally {
                setSubmitting(false);
            }
        });
    }
</script>
