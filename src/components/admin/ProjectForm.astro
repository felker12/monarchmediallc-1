---
// src/components/admin/ProjectForm.astro
import { PACKAGE_LEVELS, INDUSTRY_SECTORS } from '@data/ProjectOptions';
import type { ProjectItem } from '@data/ProjectData';
import type { SiteImageItem } from '@data/ImageData';

interface Props {
    project?: ProjectItem | null;
    images: SiteImageItem[];
}

const { project = null, images = [] } = Astro.props;

const isEditing = project !== null;
---

<dialog id="edit-project-modal" class="w-full max-w-4xl bg-transparent p-4
        backdrop:bg-black/60 backdrop:backdrop-blur-sm
        focus:outline-none">
    <section class="rounded-2xl border border-white/10 bg-[#121214] p-6 text-white shadow-2xl">
        <div class="mb-6 flex items-center justify-between border-b border-white/5 pb-3">
            <h2
                class="bg-gradient-to-r from-purple-400 via-indigo-400 to-cyan-400
                    bg-clip-text font-header text-xl font-bold text-transparent"
            >
                Edit Project: {project?.title}
            </h2>

            <button
                type="button"
                id="close-modal-btn"
                class="rounded-lg border border-white/5 bg-white/5
                    px-3 py-1.5 font-body text-xs font-medium text-gray-400
                    transition-colors hover:bg-white/10 hover:text-white
                    cursor-pointer"
            >
                Close
            </button>
        </div>

        <form method="POST" action="/api/admin/projects" class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <input type="hidden" name="id" value={project?.id} />

            <div>
                <label
                    for="edit-project-title"
                    class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400"
                >
                    Project Title *
                </label>

                <input
                    id="edit-project-title"
                    type="text"
                    name="title"
                    required
                    value={project?.title}
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div>
                <label for="edit-client-name" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Client Name
                </label>

                <input
                    id="edit-client-name"
                    type="text"
                    name="clientName"
                    value={project?.clientName || ''}
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div class="md:col-span-2">
                <label
                    for="edit-project-description"
                    class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400"
                >
                    Description *
                </label>

                <textarea
                    id="edit-project-description"
                    name="description"
                    required
                    rows="3"
                    class="w-full resize-none rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                    >{project?.description}</textarea
                >
            </div>

            <div>
                <label for="edit-tech-stack" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Tech Stack
                </label>

                <input
                    id="edit-tech-stack"
                    type="text"
                    name="techStack"
                    value={project?.techStack || ''}
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div>
                <label for="edit-live-url" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Live URL
                </label>

                <input
                    id="edit-live-url"
                    type="url"
                    name="liveUrl"
                    value={project?.liveUrl || ''}
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div class="md:col-span-2">
                <label for="edit-site-image" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Link Portfolio Image Asset
                </label>

                <select
                    id="edit-site-image"
                    name="siteImageId"
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                >
                    <option value="" selected={project?.siteImageId == null}> -- No Image / Decorative Only -- </option>

                    {
                        images.map((image) => (
                            <option value={image.id} selected={project?.siteImageId === image.id}>
                                {image.fileName}
                                {image.altText ? ` (${image.altText})` : ''}
                            </option>
                        ))
                    }
                </select>
            </div>

            <div>
                <label for="edit-package" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Service Package Tier
                </label>

                <select
                    id="edit-package"
                    name="package"
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                >
                    {
                        PACKAGE_LEVELS.map((level) => (
                            <option value={level.value} selected={project?.package.toLowerCase() === level.label.toLowerCase()}>
                                {level.label}
                            </option>
                        ))
                    }
                </select>
            </div>

            <div>
                <label for="edit-industry" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Industry Vertical
                </label>

                <select
                    id="edit-industry"
                    name="industry"
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                >
                    {
                        INDUSTRY_SECTORS.map((sector) => (
                            <option value={sector.value} selected={project?.industry.toLowerCase() === sector.label.toLowerCase()}>
                                {sector.label}
                            </option>
                        ))
                    }
                </select>
            </div>

            <div>
                <label
                    for="edit-display-order"
                    class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400"
                >
                    Display Sort Order
                </label>

                <input
                    id="edit-display-order"
                    type="number"
                    name="displayOrder"
                    value={project?.displayOrder ?? 0}
                    min="0"
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div>
                <label for="edit-completed-on" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Completion Date
                </label>

                <input
                    id="edit-completed-on"
                    type="date"
                    name="completedOn"
                    value={project?.completedOn || ''}
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3 text-sm text-white
                        transition-colors focus:border-purple-500/60
                        focus:outline-none"
                />
            </div>

            <div class="flex items-center gap-8 py-2">
                <label class="flex cursor-pointer items-center gap-2 font-body text-sm text-gray-300">
                    <input
                        type="checkbox"
                        name="featured"
                        value="true"
                        checked={project?.featured}
                        class="rounded border-white/15 bg-[#1a1a1e]
                            text-purple-500 focus:outline-none
                            focus:ring-0 focus:ring-offset-0"
                    />

                    Featured Item
                </label>

                <label class="flex cursor-pointer items-center gap-2 font-body text-sm text-gray-300">
                    <input
                        type="checkbox"
                        name="isPublic"
                        value="true"
                        checked={project?.isPublic ?? true}
                        class="rounded border-white/15 bg-[#1a1a1e]
                            text-purple-500 focus:outline-none
                            focus:ring-0 focus:ring-offset-0"
                    />

                    Publicly Visible
                </label>
            </div>

            <div class="flex items-center justify-end pt-4 md:col-span-2">
                <button
                    type="submit"
                    class="rounded-xl bg-gradient-to-r
                        from-purple-500 via-indigo-500 to-cyan-500
                        px-6 py-3.5 font-body text-xs font-semibold
                        uppercase tracking-wider text-white shadow-md
                        transition-all hover:opacity-95
                        active:scale-[0.99] cursor-pointer"
                >
                    Update Project Details
                </button>
            </div>
        </form>
    </section>
</dialog>

<script is:inline define:vars={{ isEditing }}>
    const dialog = document.getElementById('edit-project-modal');

    const closeButton = document.getElementById('close-modal-btn');

    const editForm = dialog?.querySelector('form');

    if (isEditing && dialog instanceof HTMLDialogElement) {
        dialog.showModal();
    }

    editForm?.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!(editForm instanceof HTMLFormElement)) {
            return;
        }

        const formData = new FormData(editForm);
        const data = {};

        formData.forEach((value, key) => {
            if (key === 'featured' || key === 'isPublic') {
                data[key] = value === 'true';
            } else if (key === 'siteImageId') {
                data[key] = value ? Number.parseInt(String(value), 10) : null;
            } else if (key === 'displayOrder' || key === 'id') {
                data[key] = Number.parseInt(String(value), 10);
            } else if (key === 'package' || key === 'industry') {
                data[key] = Number.parseInt(String(value), 10);
            } else {
                data[key] = value;
            }
        });

        if (!Object.hasOwn(data, 'featured')) {
            data.featured = false;
        }

        if (!Object.hasOwn(data, 'isPublic')) {
            data.isPublic = false;
        }

        try {
            const response = await fetch(editForm.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if (!response.ok) {
                const errorData = await response.json().catch(() => ({}));

                alert('Update failed: ' + (errorData.error || 'Server processing error'));

                return;
            }

            window.location.href = `${window.location.pathname}` + '?success=Project+updated+successfully!';
        } catch (error) {
            console.error('Project update failed:', error);

            alert('Network error encountered while trying to update the project.');
        }
    });

    closeButton?.addEventListener('click', () => {
        if (!(dialog instanceof HTMLDialogElement)) {
            return;
        }

        dialog.close();

        window.history.replaceState({}, '', window.location.pathname);
    });
</script>
