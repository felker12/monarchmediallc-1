---
// src/components/admin/AddProjectForm.astro
import { PACKAGE_LEVELS, INDUSTRY_SECTORS } from '@data/ProjectOptions';

interface Props {
    images: any[];
}
const { images = [] } = Astro.props;
const token = Astro.cookies.get('admin_token')?.value || '';
---

<section class="bg-[#121214] border border-white/5 rounded-2xl p-6 shadow-2xl">
    <h2 class="font-header text-xl font-bold text-white mb-6 border-b border-white/5 pb-2">Add New Project</h2>

    <form id="add-project-form" method="POST" action="/api/admin/projects" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Project Title *</label>
            <input
                type="text"
                name="title"
                required
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>
        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Client Name</label>
            <input
                type="text"
                name="clientName"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>

        <div class="md:col-span-2">
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Description *</label>
            <textarea
                name="description"
                required
                rows="3"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors resize-none"
            ></textarea>
        </div>

        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Tech Stack (Comma Separated)</label>
            <input
                type="text"
                name="techStack"
                placeholder="Astro, React, Tailwind"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>
        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Live URL</label>
            <input
                type="url"
                name="liveUrl"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>

        <div class="md:col-span-2">
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2"> Link Portfolio Image Asset </label>
            <select
                name="siteImageId"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            >
                <option value="">-- No Image / Decorative Only --</option>
                {
                    images.map((img) => (
                        <option value={img.id}>
                            {img.fileName} {img.altText ? `(${img.altText})` : ''}
                        </option>
                    ))
                }
            </select>
        </div>

        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Service Package Tier</label>
            <select
                name="package"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            >
                {PACKAGE_LEVELS.map((level) => <option value={level.value}>{level.label}</option>)}
            </select>
        </div>

        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Industry Vertical</label>
            <select
                name="industry"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            >
                {INDUSTRY_SECTORS.map((sec) => <option value={sec.value}>{sec.label}</option>)}
            </select>
        </div>

        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Display Sort Order</label>
            <input
                type="number"
                name="displayOrder"
                value="0"
                min="0"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>
        <div>
            <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Completion Date</label>
            <input
                type="date"
                name="completedOn"
                class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-purple-500/60 transition-colors"
            />
        </div>

        <div class="flex items-center gap-8 py-2">
            <label class="flex items-center gap-2 cursor-pointer font-body text-sm text-gray-300">
                <input
                    type="checkbox"
                    name="featured"
                    value="true"
                    class="rounded border-white/15 bg-[#1a1a1e] text-purple-500 focus:ring-0 focus:ring-offset-0 focus:outline-none"
                />
                Featured Item
            </label>
            <label class="flex items-center gap-2 cursor-pointer font-body text-sm text-gray-300">
                <input
                    type="checkbox"
                    name="isPublic"
                    value="true"
                    checked
                    class="rounded border-white/15 bg-[#1a1a1e] text-purple-500 focus:ring-0 focus:ring-offset-0 focus:outline-none"
                />
                Publicly Visible
            </label>
        </div>

        <div class="flex justify-end items-center md:col-span-2 pt-4">
            <button
                type="submit"
                class="bg-gradient-to-r from-purple-600 via-indigo-600 to-cyan-600 hover:opacity-95 text-white font-body font-semibold text-xs uppercase tracking-wider px-6 py-3.5 rounded-xl transition-all shadow-md active:scale-[0.99]"
            >
                Save Project Entry
            </button>
        </div>
    </form>
</section>

<script is:inline define:vars={{ token }}>
    const addForm = document.getElementById('add-project-form');

    addForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(addForm);
        const data = {};

        formData.forEach((value, key) => {
            if (key === 'featured' || key === 'isPublic') {
                data[key] = value === 'true';
            } else if (key === 'siteImageId') {
                data[key] = value ? parseInt(value, 10) : null;
            } else if (key === 'displayOrder') {
                data[key] = parseInt(value, 10);
            } else if (key === 'package' || key === 'industry') {
                data[key] = parseInt(value, 10);
            } else {
                data[key] = value;
            }
        });

        if (!data.hasOwnProperty('featured')) data['featured'] = false;
        if (!data.hasOwnProperty('isPublic')) data['isPublic'] = false;

        try {
            const res = await fetch(addForm.action, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                window.location.href = window.location.pathname + '?success=Project+created+successfully!';
            } else {
                const errData = await res.json().catch(() => ({}));
                alert('Creation failed: ' + (errData.error || 'Server error'));
            }
        } catch (err) {
            alert('Network error encountered trying to save project entry.');
        }
    });
</script>
