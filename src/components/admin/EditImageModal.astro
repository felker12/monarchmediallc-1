---
// src/components/admin/EditImageModal.astro
import { Icon } from 'astro-icon/components';

const ALT_TEXT_MAX_LENGTH = 250;
---

<dialog id="edit-modal" class="w-full max-w-md bg-transparent p-4
        backdrop:bg-black/60 backdrop:backdrop-blur-sm
        focus:outline-none">
    <section class="rounded-2xl border border-white/10
            bg-[#121214] p-6 text-white shadow-2xl">
        <header class="mb-5">
            <h3 class="bg-gradient-to-r from-purple-400 to-indigo-400
                    bg-clip-text font-header text-xl font-bold text-transparent">
                Update Image Metadata
            </h3>

            <p id="edit-file-name" class="mt-1 truncate font-body text-xs text-white/45" title=""></p>
        </header>

        <form id="edit-form" class="space-y-5">
            <input type="hidden" id="edit-image-id" name="id" />

            <!-- Image Preview -->
            <div
                class="relative flex aspect-video w-full items-center justify-center
                    overflow-hidden rounded-xl border border-white/5
                    bg-[#1a1a1e]"
            >
                <div id="edit-preview-placeholder" class="flex flex-col items-center gap-2
                        font-body text-xs text-white/30">
                    <Icon name="heroicons:photo" class="h-7 w-7" />

                    <span>Image preview</span>
                </div>

                <img id="edit-preview-img" src="" alt="Selected image preview" loading="eager" decoding="async" class="hidden h-full w-full object-contain" />
            </div>

            <!-- Alt Text -->
            <div>
                <label for="edit-alt-input" class="mb-2 block font-body text-xs font-semibold
                        uppercase tracking-wider text-gray-400">
                    Alt Text / Description
                </label>

                <input
                    type="text"
                    id="edit-alt-input"
                    name="altText"
                    maxlength={ALT_TEXT_MAX_LENGTH}
                    placeholder="Describe what is shown in the image for accessibility."
                    aria-describedby="edit-alt-guidance edit-alt-counter"
                    class="w-full rounded-xl border border-white/5
                        bg-[#1a1a1e] px-4 py-3
                        font-body text-sm text-white
                        transition-colors
                        placeholder:text-white/25
                        focus:border-purple-500/60 focus:outline-none"
                />

                <div class="mt-2 flex items-start justify-between gap-4
                        font-body text-[11px] text-white/35">
                    <p id="edit-alt-guidance" class="leading-4">Briefly describe the image’s meaningful visual content.</p>

                    <span id="edit-alt-counter" class="shrink-0 tabular-nums" aria-live="polite">
                        0 / {ALT_TEXT_MAX_LENGTH}
                    </span>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex justify-end gap-3
                    border-t border-white/5 pt-3">
                <button
                    type="button"
                    id="close-edit-modal-btn"
                    class="cursor-pointer rounded-xl border border-white/5
                        bg-white/5 px-4 py-2.5
                        font-body text-xs font-semibold uppercase tracking-wider
                        transition-colors hover:bg-white/10"
                >
                    Cancel
                </button>

                <button
                    type="submit"
                    id="edit-submit-btn"
                    class="inline-flex min-w-35 cursor-pointer
                        items-center justify-center gap-2
                        rounded-xl bg-indigo-600 px-5 py-2.5
                        font-body text-xs font-semibold uppercase tracking-wider
                        text-white shadow-md
                        transition-colors hover:bg-indigo-500
                        disabled:cursor-not-allowed disabled:opacity-60"
                >
                    <Icon id="edit-submit-icon" name="heroicons:check" class="h-4 w-4" />

                    <span id="edit-submit-text"> Save Changes </span>
                </button>
            </div>
        </form>
    </section>
</dialog>

<script is:inline define:vars={{ ALT_TEXT_MAX_LENGTH }}>
    {
        const editModal = document.getElementById('edit-modal');

        const editForm = document.getElementById('edit-form');

        const editFileName = document.getElementById('edit-file-name');

        const editIdInput = document.getElementById('edit-image-id');

        const editAltInput = document.getElementById('edit-alt-input');

        const editAltCounter = document.getElementById('edit-alt-counter');

        const editPreviewImage = document.getElementById('edit-preview-img');

        const editPreviewPlaceholder = document.getElementById('edit-preview-placeholder');

        const closeEditButton = document.getElementById('close-edit-modal-btn');

        const editSubmitButton = document.getElementById('edit-submit-btn');

        const editSubmitIcon = document.getElementById('edit-submit-icon');

        const editSubmitText = document.getElementById('edit-submit-text');

        const updateCharacterCounter = () => {
            if (!(editAltInput instanceof HTMLInputElement) || !editAltCounter) {
                return;
            }

            editAltCounter.textContent = `${editAltInput.value.length} / ${ALT_TEXT_MAX_LENGTH}`;
        };

        const setSubmittingState = (isSubmitting) => {
            if (editSubmitButton instanceof HTMLButtonElement) {
                editSubmitButton.disabled = isSubmitting;
            }

            if (editSubmitText) {
                editSubmitText.textContent = isSubmitting ? 'Saving...' : 'Save Changes';
            }

            if (editSubmitIcon) {
                editSubmitIcon.classList.toggle('animate-spin', isSubmitting);

                editSubmitIcon.setAttribute('data-icon', isSubmitting ? 'heroicons:arrow-path' : 'heroicons:check');
            }
        };

        const resetModal = () => {
            if (editForm instanceof HTMLFormElement) {
                editForm.reset();
            }

            if (editIdInput instanceof HTMLInputElement) {
                editIdInput.value = '';
            }

            if (editFileName) {
                editFileName.textContent = '';
                editFileName.removeAttribute('title');
            }

            if (editPreviewImage instanceof HTMLImageElement) {
                editPreviewImage.removeAttribute('src');
                editPreviewImage.classList.add('hidden');
            }

            editPreviewPlaceholder?.classList.remove('hidden');

            updateCharacterCounter();
            setSubmittingState(false);
        };

        const closeModal = () => {
            if (editModal instanceof HTMLDialogElement && editModal.open) {
                editModal.close();
            }
        };

        document.addEventListener('click', (event) => {
            const target = event.target;

            if (!(target instanceof Element)) {
                return;
            }

            const editButton = target.closest('.edit-image-btn');

            if (!(editButton instanceof HTMLButtonElement)) {
                return;
            }

            const imageId = editButton.dataset.editId ?? '';

            const imageUrl = editButton.dataset.editUrl ?? '';

            const altText = editButton.dataset.editAlt ?? '';

            const fileName = editButton.dataset.editFilename ?? '';

            if (editFileName) {
                editFileName.textContent = fileName;
                editFileName.title = fileName;
            }

            if (editIdInput instanceof HTMLInputElement) {
                editIdInput.value = imageId;
            }

            if (editAltInput instanceof HTMLInputElement) {
                editAltInput.value = altText;
            }

            updateCharacterCounter();

            if (editPreviewImage instanceof HTMLImageElement && imageUrl) {
                editPreviewImage.src = imageUrl;
                editPreviewImage.alt = fileName ? `Preview of ${fileName}` : 'Selected image preview';

                editPreviewImage.classList.remove('hidden');
                editPreviewPlaceholder?.classList.add('hidden');
            }

            if (editModal instanceof HTMLDialogElement) {
                editModal.showModal();

                requestAnimationFrame(() => {
                    if (editAltInput instanceof HTMLInputElement) {
                        editAltInput.focus();
                        editAltInput.select();
                    }
                });
            }
        });

        editAltInput?.addEventListener('input', updateCharacterCounter);

        closeEditButton?.addEventListener('click', closeModal);

        /*
         * Clicking the dialog backdrop makes the dialog itself
         * the event target. Clicking the inner section does not.
         */
        editModal?.addEventListener('click', (event) => {
            if (event.target === editModal) {
                closeModal();
            }
        });

        /*
         * The native dialog fires close for the Cancel button,
         * backdrop handler, Escape key, and direct close calls.
         */
        editModal?.addEventListener('close', resetModal);

        editForm?.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (!(editIdInput instanceof HTMLInputElement) || !(editAltInput instanceof HTMLInputElement)) {
                return;
            }

            const imageId = editIdInput.value;

            if (!imageId) {
                alert('The image ID is missing.');
                return;
            }

            setSubmittingState(true);

            try {
                const response = await fetch(`/api/admin/images/${imageId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        altText: editAltInput.value.trim()
                    })
                });

                if (!response.ok) {
                    const responseText = await response.text();

                    let errorMessage = responseText || 'Failed to update image metadata.';

                    try {
                        const errorData = JSON.parse(responseText);

                        errorMessage = errorData.error ?? errorData.message ?? responseText;
                    } catch {
                        // Preserve a plain-text server response.
                    }

                    alert(errorMessage);
                    setSubmittingState(false);

                    return;
                }

                window.location.reload();
            } catch (error) {
                console.error('Image metadata update failed:', error);

                alert('Network error while updating image metadata.');

                setSubmittingState(false);
            }
        });

        updateCharacterCounter();
    }
</script>
