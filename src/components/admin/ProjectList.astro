---
// src/components/admin/project-manager/ProjectList.astro
import type { ProjectItem } from '@data/ProjectData';

interface Props {
    projects: ProjectItem[];
}

const { projects } = Astro.props;

// Helper maps to translate backend enum integers to readable label UI
const packageMap: Record<number, string> = {
    0: 'Core',
    1: 'Professional',
    2: 'Premium'
};
const industryMap: Record<number, string> = {
    0: 'General',
    1: 'Construction',
    2: 'Landscaping',
    3: 'Restaurant',
    4: 'Healthcare',
    5: 'Law Firm',
    6: 'Technology'
};
---

<section class="space-y-4">
    <h2 class="font-header text-xl font-bold text-white border-b border-white/5 pb-2">Active Database Pointers ({projects.length})</h2>

    <div class="bg-[#121214] border border-white/5 rounded-2xl overflow-hidden shadow-xl">
        {
            projects.length === 0 ? (
                <p class="p-8 text-center text-gray-500 font-body text-sm italic">No entries returned from the Azure Database.</p>
            ) : (
                <div class="divide-y divide-white/5">
                    {projects.map((proj) => (
                        <div class="py-7 px-6 flex flex-col sm:flex-row sm:items-center justify-between hover:bg-white/[0.015] transition-all duration-200 gap-6 group">
                            <div class="flex items-start gap-5 min-w-0 flex-1">
                                <div class="w-16 h-16 bg-[#1a1a1e] rounded-xl border border-white/10 overflow-hidden flex-shrink-0 flex items-center justify-center shadow-md mt-0.5 group-hover:border-white/20 transition-colors">
                                    {proj.siteImage?.publicUrl ? (
                                        <img src={proj.siteImage.publicUrl} alt={proj.siteImage.altText || proj.title} class="w-full h-full object-cover" />
                                    ) : (
                                        <span class="text-[10px] text-gray-600 italic">No Img</span>
                                    )}
                                </div>

                                <div class="truncate space-y-2 flex-1">
                                    <div class="flex flex-wrap items-center gap-2.5">
                                        <h3 class="font-body font-bold text-base text-white truncate tracking-tight">{proj.title}</h3>

                                        <div class="flex items-center gap-1.5">
                                            <span class="bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 font-body text-[9px] uppercase font-bold px-2.5 py-0.5 rounded-md tracking-wider">
                                                {packageMap[proj.package] || 'Core'}
                                            </span>

                                            <span class="bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 font-body text-[9px] uppercase font-bold px-2.5 py-0.5 rounded-md tracking-wider">
                                                {industryMap[proj.industry] || 'General'}
                                            </span>

                                            {proj.featured && (
                                                <span class="bg-amber-500/10 border border-amber-500/20 text-amber-400 font-body text-[9px] uppercase font-bold px-2.5 py-0.5 rounded-md tracking-wider">
                                                    Featured
                                                </span>
                                            )}

                                            <span
                                                class={`font-body text-[9px] uppercase font-bold px-2.5 py-0.5 rounded-md tracking-wider ${proj.isPublic ? 'bg-emerald-500/10 border border-emerald-500/20 text-emerald-400' : 'bg-zinc-500/10 border border-zinc-500/20 text-zinc-400'}`}
                                            >
                                                {proj.isPublic ? 'Public' : 'Hidden'}
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text-sm text-gray-400 truncate font-body">
                                        <span class="text-gray-200 font-medium">{proj.clientName || 'Internal Project'}</span>
                                        <span class="mx-2 text-white/10">•</span> Order Sequence:{' '}
                                        <span class="text-gray-300 font-medium">{proj.displayOrder}</span>
                                    </p>
                                </div>
                            </div>

                            <div class="flex items-center gap-3 self-end sm:self-center flex-shrink-0">
                                <a
                                    href={`/admin/projects?edit=${proj.id}`}
                                    class="text-xs text-gray-300 hover:text-white px-4 py-2.5 rounded-xl border border-white/5 transition-all font-body font-semibold min-w-[65px] text-center active:scale-[0.98]"
                                >
                                    Edit
                                </a>

                                <form
                                    method="POST"
                                    action="/api/admin/projects"
                                    onsubmit="return confirm('Are you sure you want to permanently delete this project?');"
                                    class="inline m-0"
                                >
                                    <input type="hidden" name="id" value={proj.id} />
                                    <input type="hidden" name="action" value="delete" />
                                    <button
                                        type="submit"
                                        class="text-xs bg-red-500/10 hover:bg-red-500/20 text-red-400 hover:text-red-300 px-4 py-2.5 rounded-xl border border-red-500/10 transition-all font-body font-semibold active:scale-[0.98]"
                                    >
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    ))}
                </div>
            )
        }
    </div>
</section>
