---
import { Icon } from 'astro-icon/components';
import type { MonarchCarePlan } from '@data/MonarchCareTypes';
import { formatCarePlanAllowance, formatCarePlanPrice } from '@data/MonarchCarePlans';

interface Props {
    plan: MonarchCarePlan;
}

const { plan } = Astro.props;

const categoryClasses: Record<MonarchCarePlan['category'], string> = {
    Technical: 'border-white/10',
    Content: 'border-header/60 shadow-[0_0_45px_rgba(232,207,124,0.1)] lg:-translate-y-3',
    Growth: 'border-complementary/55',
    Enterprise: 'border-primary/70'
};
---

<article
    class:list={[
        'relative flex h-full flex-col rounded-2xl border bg-[#0c0c0e]/90 p-6 backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:border-header/40',
        categoryClasses[plan.category]
    ]}
>
    {
        plan.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full border border-white/10 bg-gradient-to-r from-complementary to-primary px-4 py-1 font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white">
                Recommended
            </span>
        )
    }

    <header>
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.22em] text-complementary">
            {plan.category} plan
        </p>

        <h2 class="mt-2 font-header text-3xl text-white">
            {plan.name}
        </h2>

        <p class="mt-2 min-h-12 font-body text-sm italic leading-6 text-white/50">
            {plan.tagline}
        </p>

        <p class="mt-5 border-y border-white/5 py-4 font-header text-3xl text-white">
            {formatCarePlanPrice(plan)}
        </p>
    </header>

    <section class="mt-5">
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white/35">Best for</p>

        <p class="mt-2 line-clamp-3 font-body text-sm leading-6 text-white/70">
            {plan.idealFor}
        </p>
    </section>

    <section class="mt-6 flex-1">
        <p class="font-body text-[10px] font-bold uppercase tracking-[0.2em] text-white/35">Included</p>

        <ul class="mt-3 space-y-2">
            {
                plan.allowances.slice(0, 3).map((allowance) => (
                    <li class="flex items-start gap-3 rounded-lg border border-white/5 bg-white/[0.025] px-3 py-2.5">
                        <Icon name="heroicons:shield-check" class="mt-0.5 h-4 w-4 shrink-0 text-complementary" />
                        <span class="font-body text-sm font-semibold leading-5 text-header">{formatCarePlanAllowance(allowance)}</span>
                    </li>
                ))
            }
        </ul>
    </section>

    <dl class="mt-6 space-y-3 border-t border-white/5 pt-5 font-body text-sm">
        <div class="flex justify-between gap-5">
            <dt class="text-white/35">Response time</dt>
            <dd class="text-right text-white/70">
                {plan.responseTime}
            </dd>
        </div>

        {
            plan.minimumCommitmentMonths && (
                <div class="flex justify-between gap-5">
                    <dt class="text-white/35">Initial term</dt>
                    <dd class="text-right text-white/70">{plan.minimumCommitmentMonths} months</dd>
                </div>
            )
        }
    </dl>

    <div class="mt-6 grid gap-3">
        <a
            href={`/contact?care=${plan.id}`}
            class:list={[
                'btn w-full rounded-lg py-3 font-body text-xs uppercase tracking-[0.16em]',
                plan.featured ? 'bg-primary text-white hover:bg-primary/85' : 'border border-white/10 bg-white/[0.035] hover:bg-white/[0.08]'
            ]}
        >
            {plan.ctaLabel}
        </a>

        <a href="#care-comparison" class="text-center font-body text-xs font-semibold text-white/45 transition hover:text-header"> Compare full coverage </a>
    </div>
</article>
