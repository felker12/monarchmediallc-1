---
// src/components/NavBar.astro
import { publicItems } from '@data/NavData';
import { Icon } from 'astro-icon/components';

const currentPath = Astro.url.pathname;

const isContactActive = currentPath === '/contact' || currentPath.startsWith('/contact/');

const getLinkClass = (href: string) => {
    const isCurrent = href === '/' ? currentPath === '/' : currentPath.startsWith(href);

    return isCurrent
        ? 'text-white bg-white/10 shadow-[inset_0_0_12px_rgba(255,255,255,0.05)] border-t border-white/5 font-semibold'
        : 'text-gray-400 hover:text-white hover:bg-white/5 active:bg-white/10';
};
---

<nav class="relative flex items-center gap-4 sm:gap-6">
    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-1 sm:gap-2 font-body text-sm font-medium tracking-wide">
        {
            publicItems.map((item) => (
                <li>
                    <a href={item.href} class={`inline-block px-3 py-2 rounded-lg transition-all duration-200 ${getLinkClass(item.href)}`}>
                        {item.linkText}
                    </a>
                </li>
            ))
        }
    </ul>

    <!-- Desktop Contact CTA -->
    <div class="hidden md:block">
        <a
            href="/contact"
            class={`relative inline-flex items-center justify-center overflow-hidden
                rounded-xl border px-5 py-2.5
                font-body text-xs font-bold uppercase tracking-[0.15em]
                transition-all duration-300 group
                ${
                    isContactActive
                        ? 'border-complementary bg-[#0c0c0e]/90 text-white shadow-[0_4px_25px_rgba(136,69,124,0.35)]'
                        : 'border-white/10 bg-[#0c0c0e]/60 text-white/90 backdrop-blur-md shadow-[0_4px_20px_rgba(0,0,0,0.35)] hover:border-complementary/50 hover:text-white hover:shadow-[0_4px_25px_rgba(136,69,124,0.25)]'
                }`}
        >
            <span
                class={`absolute top-0 h-[1.5px]
                    bg-gradient-to-r from-transparent via-complementary to-transparent
                    transition-all duration-300
                    ${
                        isContactActive
                            ? 'left-1 right-1 via-complementary'
                            : 'left-3 right-3 via-complementary/60 group-hover:left-1 group-hover:right-1 group-hover:via-complementary'
                    }`}></span>

            <span
                class={`absolute inset-0
                    bg-gradient-to-b from-primary/15 to-transparent
                    transition-opacity duration-300
                    ${isContactActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}></span>

            <span class="relative z-10"> Get in touch </span>
        </a>
    </div>

    <!-- Mobile Toggle -->
    <button
        id="public-menu-toggle"
        type="button"
        class="relative md:hidden flex h-10 w-10 items-center justify-center
            rounded-xl border border-transparent
            text-gray-400
            transition-all duration-200
            hover:bg-white/5 hover:text-white
            active:scale-95
            focus-visible:outline-none focus-visible:ring-2
            focus-visible:ring-complementary/60"
        aria-label="Open menu"
        aria-controls="public-mobile-menu"
        aria-expanded="false"
    >
        <Icon
            name="heroicons:bars-3"
            class="menu-open-icon absolute h-6 w-6
                opacity-100 rotate-0 scale-100
                transition-[opacity,transform] duration-200"
        />

        <Icon
            name="heroicons:x-mark"
            class="menu-close-icon absolute h-6 w-6
                opacity-0 -rotate-90 scale-75
                transition-[opacity,transform] duration-200"
        />
    </button>

    <!-- Mobile Menu -->
    <div
        id="public-mobile-menu"
        class="absolute right-0 top-full z-50 mt-2 w-52
            origin-top-right rounded-xl
            border border-white/5 bg-[#121214]/95
            p-2 shadow-2xl backdrop-blur-md
            opacity-0 invisible scale-95
            transition-[opacity,transform,visibility] duration-200
            md:hidden"
    >
        <ul class="space-y-1 font-body text-sm font-medium">
            {
                publicItems.map((item) => (
                    <li>
                        <a href={item.href} class={`mobile-nav-link block px-3 py-2 rounded-lg transition-all duration-200 ${getLinkClass(item.href)}`}>
                            {item.linkText}
                        </a>
                    </li>
                ))
            }

            <!-- Mobile Contact CTA -->
            <li class="pt-2 mt-2 border-t border-white/5">
                <a
                    href="/contact"
                    class={`mobile-nav-link relative block overflow-hidden
                        rounded-lg border px-3 py-2.5 text-center
                        font-body text-xs font-bold uppercase tracking-[0.12em]
                        transition-all duration-300 group
                        ${
                            isContactActive
                                ? 'border-complementary bg-[#0c0c0e] text-white shadow-[0_4px_15px_rgba(136,69,124,0.2)]'
                                : 'border-white/10 bg-[#0c0c0e]/80 text-white/90 hover:border-complementary/40 hover:text-white'
                        }`}
                >
                    <span
                        class={`absolute top-0 h-[1.5px]
                            bg-gradient-to-r from-transparent via-complementary to-transparent
                            transition-all duration-300
                            ${
                                isContactActive
                                    ? 'left-1 right-1 via-complementary'
                                    : 'left-4 right-4 via-complementary/60 group-hover:left-1 group-hover:right-1'
                            }`}></span>

                    <span class="relative z-10"> Get in touch </span>
                </a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const toggleButton = document.getElementById('public-menu-toggle');

    const mobileMenu = document.getElementById('public-mobile-menu');

    const openIcon = toggleButton?.querySelector('.menu-open-icon');

    const closeIcon = toggleButton?.querySelector('.menu-close-icon');

    const setMobileMenuState = (isOpen: boolean) => {
        if (!toggleButton || !mobileMenu) {
            return;
        }

        toggleButton.setAttribute('aria-expanded', String(isOpen));

        toggleButton.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');

        toggleButton.classList.toggle('bg-white/5', isOpen);

        toggleButton.classList.toggle('border-white/10', isOpen);

        toggleButton.classList.toggle('text-white', isOpen);

        mobileMenu.classList.toggle('opacity-0', !isOpen);

        mobileMenu.classList.toggle('invisible', !isOpen);

        mobileMenu.classList.toggle('scale-95', !isOpen);

        openIcon?.classList.toggle('opacity-0', isOpen);

        openIcon?.classList.toggle('rotate-180', isOpen);

        openIcon?.classList.toggle('scale-75', isOpen);

        openIcon?.classList.toggle('opacity-100', !isOpen);

        openIcon?.classList.toggle('rotate-0', !isOpen);

        openIcon?.classList.toggle('scale-100', !isOpen);

        closeIcon?.classList.toggle('opacity-100', isOpen);

        closeIcon?.classList.toggle('rotate-0', isOpen);

        closeIcon?.classList.toggle('scale-100', isOpen);

        closeIcon?.classList.toggle('opacity-0', !isOpen);

        closeIcon?.classList.toggle('-rotate-90', !isOpen);

        closeIcon?.classList.toggle('scale-75', !isOpen);
    };

    if (toggleButton && mobileMenu) {
        toggleButton.addEventListener('click', (event) => {
            event.stopPropagation();

            const isOpen = toggleButton.getAttribute('aria-expanded') === 'true';

            setMobileMenuState(!isOpen);
        });

        mobileMenu.querySelectorAll('.mobile-nav-link').forEach((link) => {
            link.addEventListener('click', () => {
                setMobileMenuState(false);
            });
        });

        document.addEventListener('click', (event) => {
            const target = event.target;

            if (!(target instanceof Node)) {
                return;
            }

            if (!mobileMenu.contains(target) && !toggleButton.contains(target)) {
                setMobileMenuState(false);
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && toggleButton.getAttribute('aria-expanded') === 'true') {
                setMobileMenuState(false);
                toggleButton.focus();
            }
        });
    }
</script>
