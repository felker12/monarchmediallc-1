---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { socialLinks } from '@data/SocialData';
import logo from '@assets/MonarchPurple.png';
---

<div class="relative flex flex-col items-center justify-center px-4 pb-4 max-w-6xl mx-auto min-h-svh">
    <div
        id="purpleblob"
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-[60vh] w-[60vh]
            -translate-x-1/2 -translate-y-1/2 rounded-full
            bg-primary opacity-40 blur-[40px]"
    >
    </div>

    <Image src={logo} alt="Monarch Media LLC's logo" class="z-10 mb-2 w-48 drop-shadow-2xl" />

    <h1
        class="z-10 bg-gradient-to-b from-white to-gray-400 bg-clip-text
                pb-4 text-center font-header font-bold tracking-tight
                text-transparent text-5xl"
    >
        Web Design & Digital Marketing in Terre Haute
    </h1>

    <section id="services" aria-labelledby="services-heading" class="z-10 pb-8 text-center">
        <h2 id="services-heading" class="sr-only">Our Creative and Digital Services</h2>

        <p class="font-body text-sm font-semibold uppercase
            tracking-[0.2em] text-gray-400 md:text-base">
            Social Media
            <span aria-hidden="true" class="text-complementary">|</span>
            Branding
            <span aria-hidden="true" class="text-complementary">|</span>
            Web Design
        </p>
    </section>

    <p class="z-10 max-w-xl pb-8 text-center font-body text-base leading-relaxed
            text-gray-300 md:text-lg">
        Metamorphosis in progress. Our full website is coming soon.
    </p>

    <p class="z-10 max-w-2xl pb-8 text-center font-body text-base
        leading-relaxed text-gray-300 md:text-lg">
        Monarch Media LLC helps businesses in Terre Haute and throughout the Wabash Valley build stronger brands through custom websites, graphic design, social
        media, and digital marketing.
    </p>

    <div class="z-10 mb-8 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="rounded-lg bg-primary px-6 py-3 font-semibold text-white
            transition hover:bg-primary/80"> Start a Project </a>

        <a
            href="/web-development"
            class="rounded-lg border border-white/20 px-6 py-3 font-semibold
            text-white transition hover:border-primary/60 hover:bg-white/5"
        >
            View Website Packages
        </a>
    </div>

    <div class="z-10 flex items-center gap-6">
        {
            socialLinks.map((link) => {
                const isExternal = link.href.startsWith('http');

                return (
                    <a
                        href={link.href}
                        aria-label={link.label}
                        title={link.title}
                        target={isExternal ? '_blank' : undefined}
                        rel={isExternal ? 'noopener noreferrer' : undefined}
                        class="flex h-10 w-10 items-center justify-center rounded-full
                            border border-white/10 bg-white/[0.025] text-gray-400
                            transition-all duration-200
                            hover:-translate-y-1 hover:scale-105
                            hover:border-primary/50 hover:bg-primary/15 hover:text-white"
                    >
                        <Icon name={link.icon} class="h-5 w-5" aria-hidden="true" />
                    </a>
                );
            })
        }
    </div>
</div>
