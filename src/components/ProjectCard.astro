---
// src/components/ProjectCard.astro
import { Image } from 'astro:assets';
import type { ProjectItem } from '@data/ProjectData';

interface Props {
    project: ProjectItem;
    loading?: 'lazy' | 'eager';
}

const { project, loading = 'lazy' } = Astro.props;

const imageUrl = project.siteImage?.publicUrl;
const imageAlt = project.siteImage?.altText || project.title || 'Showcase project image';
---

<article
    class="group relative flex h-full w-full max-w-none flex-col
        overflow-hidden rounded-2xl border border-white/5
        bg-[#0c0c0e]
        transition-all duration-500
        hover:-translate-y-1
        hover:border-primary/40
        hover:shadow-[0_18px_45px_rgba(69,26,107,0.16)]"
>
    {
        project.featured && (
            <span
                class="absolute right-3 top-3 z-20
                    rounded-md border border-white/10
                    bg-gradient-to-r from-complementary to-primary
                    px-2.5 py-1
                    font-body text-[9px] font-bold uppercase
                    tracking-[0.14em] text-white shadow-lg"
            >
                Featured
            </span>
        )
    }

    <div class="relative w-full overflow-hidden
            border-b border-white/5 bg-[#121214]
            aspect-[4/3]">
        {
            imageUrl ? (
                <a
                    href={imageUrl}
                    data-pswp-width="1920"
                    data-pswp-height="1080"
                    target="_blank"
                    rel="noreferrer"
                    aria-label={`View a larger preview of ${project.title}`}
                    class="portfolio-lightbox-trigger block h-full w-full cursor-zoom-in"
                >
                    <div
                        class="absolute inset-0 z-10
                            bg-gradient-to-t from-black/35 via-transparent to-transparent
                            opacity-50 transition-opacity duration-500
                            group-hover:opacity-20"
                    />

                    <Image
                        src={imageUrl}
                        alt={imageAlt}
                        width={800}
                        height={600}
                        loading={loading}
                        class="h-full w-full object-cover
                            transition-transform duration-700 ease-out
                            group-hover:scale-[1.04]"
                    />
                </a>
            ) : (
                <div
                    class="flex h-full w-full items-center justify-center
                        font-body text-xs italic text-gray-600"
                >
                    Image Coming Soon
                </div>
            )
        }
    </div>

    <div class="flex flex-1 flex-col p-5">
        <div class="flex-1">
            {
                project.industry && (
                    <p
                        class="font-body text-[9px] font-semibold uppercase
                            tracking-[0.16em] text-gray-500"
                    >
                        {project.industry}
                    </p>
                )
            }

            <h3
                class="mt-2 font-header text-lg font-bold
                    leading-snug tracking-tight text-white
                    transition-colors duration-300
                    group-hover:text-complementary"
            >
                {project.title}
            </h3>

            <p class="mt-2 line-clamp-2
                    font-body text-sm leading-6 text-gray-400/85">
                {project.description || 'A custom-designed digital platform built around performance, usability, and long-term business growth.'}
            </p>
        </div>

        {
            project.liveUrl && (
                <div class="mt-5 border-t border-white/5 pt-4">
                    <a
                        href={project.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center
                            rounded-lg border border-purple-500/20
                            bg-purple-500/10 px-4 py-2
                            font-body text-[10px] font-semibold uppercase
                            tracking-[0.14em] text-white
                            transition-all duration-300
                            hover:border-purple-400/40
                            hover:bg-purple-500/20
                            hover:text-purple-300"
                    >
                        Visit Website
                    </a>
                </div>
            )
        }
    </div>
</article>
