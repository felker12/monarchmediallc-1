---
// src/components/Header.astro
import { Image } from 'astro:assets';
import NavBar from '@components/NavBar.astro';
import AdminNavBar from '@components/AdminNavBar.astro';

import logoImage from '@assets/MonarchPurple.png';

const currentPath = Astro.url.pathname;
const isAdminRoute = currentPath.startsWith('/admin') && currentPath !== '/admin/login';
---

<header class="relative z-20 w-full border-b border-white/15 px-4">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between py-2">
        <a href="/" aria-label="Monarch Media LLC home" class="flex transition-transform duration-200 hover:scale-105">
            <Image src={logoImage} alt="" width={60} height={60} class="mb-2 w-15 drop-shadow-2xl" loading="eager" />
        </a>

        {isAdminRoute ? <AdminNavBar /> : <NavBar />}
    </div>
</header>
