---
const navItems = [
    { linkText: 'Home', href: '/' },
    { linkText: 'Portfolio', href: '/portfolio' }
    //{ linkText: 'Contact', href: '/contact' }
];
---

<header class="w-full max-w-7xl mx-auto px-4 relative z-20">
    <nav class="flex items-center justify-between py-2 border-b border-white/15">
        <!-- Logo Wrapper -->
        <a href="/" class="transition-transform duration-200 hover:scale-[1.05] flex items-center">
            <img src="/images/MonarchPurple.png" alt="Monarch Media logo" class="w-15 mb-2 drop-shadow-2xl" />
        </a>

        <!-- Navigation Links -->
        {
            !!navItems?.length && (
                <ul class="flex items-center gap-2 sm:gap-4 font-body text-sm font-medium tracking-wide text-gray-400">
                    {navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class="inline-block px-3 py-2 rounded-lg transition-all duration-200 hover:text-white hover:bg-white/5 active:bg-white/10"
                            >
                                {item.linkText}
                            </a>
                        </li>
                    ))}
                </ul>
            )
        }
    </nav>
</header>
