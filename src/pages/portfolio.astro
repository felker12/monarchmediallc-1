---
export const prerender = false; // Tells Netlify to fetch from the DB at runtime on every page hit

import Layout from '@layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';
import type { Database, ProjectItem } from '@data/ProjectData';

//Initialize the Supabase Client with the prefixed public variables
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_KEY;

const supabase = createClient<Database>(SUPABASE_URL, SUPABASE_KEY);

//Fetch items from the public.MMLLC_Projects table matching database columns
const { data, error } = await supabase
    .from('MMLLC_Projects')
    .select('*')
    .eq('visible', true) //Only fetch projects where visible is true
    .order('display_order', { ascending: true })
    .order('created_at', { ascending: true }); // Order by display_order first, then created_at as a fallback

const projects = data as ProjectItem[] | null;
---

<Layout title="Monarch Media LLC | Portfolio">
    <div class="px-4 relative z-10 max-w-7xl mx-auto py-12 sm:py-16 min-h-[80svh]">
        <div class="text-center mb-12">
            <h1 class="pb-2 font-header text-4xl md:text-6xl font-bold bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                Our Portfolio
            </h1>
            <p class="text-gray-400 font-body text-sm uppercase tracking-[0.2em] font-semibold">
                Social Media <span class="text-[#451a6b]">|</span> Marketing <span class="text-[#451a6b]">|</span> Web Design
            </p>
        </div>

        {
            error && (
                <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-6 text-center max-w-xl mx-auto">
                    <p class="text-red-400 font-body font-medium">Unable to load portfolio items at this time.</p>
                </div>
            )
        }

        {
            !error && (!projects || projects.length === 0) && (
                <p class="text-gray-400 font-body text-center py-12">No projects showcased just yet. Check back soon!</p>
            )
        }

        <div id="photo-gallery" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center justify-center">
            {
                projects?.map((project) => (
                    <div class="relative w-full max-w-sm md:max-w-none bg-[#121214] rounded-2xl border border-white/5 hover:border-[#451a6b]/40 hover:shadow-2xl hover:shadow-[#451a6b]/5 transition-all duration-300 group flex flex-col overflow-hidden">
                        {project.featured && (
                            <span class="absolute top-4 right-4 z-20 bg-gradient-to-r from-amber-200 to-yellow-500 text-[#020001] font-body font-bold text-xs px-2.5 py-1 rounded-full shadow-md uppercase tracking-wider">
                                Featured
                            </span>
                        )}

                        <div class="relative overflow-hidden aspect-video w-full border-b border-white/5 bg-[#1a1a1e]">
                            {project.img_path ? (
                                <a
                                    href={project.img_path}
                                    data-pswp-width="1920"
                                    data-pswp-height="1080"
                                    target="_blank"
                                    rel="noreferrer"
                                    class="portfolio-lightbox-trigger block w-full h-full cursor-zoom-in"
                                >
                                    <img
                                        src={project.img_path}
                                        alt={project.img_alt_text || `Showcase for ${project.project_name}`}
                                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                                        loading="lazy"
                                    />
                                </a>
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-gray-600 font-body text-xs italic">Image Coming Soon</div>
                            )}
                        </div>

                        <div class="p-6 flex flex-col justify-between flex-grow space-y-6 text-center">
                            <div class="space-y-2">
                                <h3 class="font-body font-bold text-xl text-white tracking-tight leading-tight group-hover:text-gray-200 transition-colors">
                                    {project.project_name}
                                </h3>

                                {project.client_name && (
                                    <p class="font-body text-xs text-[#e8cf7c]/90 font-medium uppercase tracking-wider">Client: {project.client_name}</p>
                                )}

                                <p class="font-body text-sm text-gray-400 leading-relaxed pt-2">{project.tech_stack}</p>
                            </div>

                            {project.live_url && (
                                <div class="pt-2 flex justify-center">
                                    <a
                                        href={project.live_url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 font-body font-semibold text-xs uppercase tracking-wider text-white hover:text-[#e8cf7c] transition-colors group/link"
                                    >
                                        View Live Project
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke-width="2.5"
                                            stroke="currentColor"
                                            class="w-3 h-3 transform group-hover/link:translate-x-1 transition-transform"
                                        >
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                                        </svg>
                                    </a>
                                </div>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</Layout>

<script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
        gallery: '#photo-gallery',
        // Target ONLY the anchor links containing the lightbox class
        children: 'a.portfolio-lightbox-trigger',
        pswpModule: () => import('photoswipe')
    });

    lightbox.init();
</script>
