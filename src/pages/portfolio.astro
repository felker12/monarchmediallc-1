---
// src/pages/portfolio.astro
import Layout from '@layouts/Layout.astro';
import type { ProjectItem } from '@data/ProjectData';
import ProjectCard from '@components/ProjectCard.astro';

const targetUrl = new URL('/api/projects', import.meta.env.AZURE_API_URL).href;

let projects: ProjectItem[] | null = null;
let error = false;

try {
    const response = await fetch(targetUrl);

    if (!response.ok) {
        throw new Error(`API returned status: ${response.status}`);
    }

    projects = (await response.json()) as ProjectItem[];
} catch (e) {
    console.error('Failed fetching projects from Azure API:', e);
    error = true;
}
---

<Layout title="Monarch Media LLC | Portfolio">
    <div class="px-4 relative z-10 max-w-7xl mx-auto py-12 sm:py-16 min-h-[80svh]">
        <div class="text-center mb-12">
            <h1 class="pb-2 font-header text-4xl md:text-6xl font-bold bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                Our Portfolio
            </h1>
            <p class="text-gray-400 font-body text-sm uppercase tracking-[0.2em] font-semibold">
                Social Media <span class="text-[#451a6b]">|</span> Marketing <span class="text-[#451a6b]">|</span> Web Design
            </p>
        </div>

        {
            error && (
                <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-6 text-center max-w-xl mx-auto">
                    <p class="text-red-400 font-body font-medium">Unable to load portfolio items at this time.</p>
                </div>
            )
        }

        {
            !error && (!projects || projects.length === 0) && (
                <p class="text-gray-400 font-body text-center py-12">No projects showcased just yet. Check back soon!</p>
            )
        }

        <div id="photo-gallery" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center justify-center">
            {projects?.map((project, index) => <ProjectCard project={project} loading={index === 0 ? 'eager' : 'lazy'} />)}
        </div>
    </div>
</Layout>

<script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    const lightbox = new PhotoSwipeLightbox({
        gallery: '#photo-gallery',
        children: 'a.portfolio-lightbox-trigger',
        pswpModule: () => import('photoswipe')
    });

    lightbox.init();
</script>
