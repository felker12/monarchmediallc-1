---
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

export const prerender = false;

if (!Astro.cookies.has('admin_token')) {
    return Astro.redirect('/admin/login');
}

const GOATCOUNTER_SUBDOMAIN = 'monarchmediallc';
const BASE_URL = `https://${GOATCOUNTER_SUBDOMAIN}.goatcounter.com/counter//.json`;

async function fetchViews(params = '') {
    try {
        const response = await fetch(`${BASE_URL}${params}`);

        if (!response.ok) {
            return '0';
        }

        const data = await response.json();

        return data.count || '0';
    } catch {
        return '—';
    }
}

const [viewsToday, viewsWeek, viewsMonth, viewsYear] = await Promise.all([
    fetchViews('?start=today'),
    fetchViews('?start=week'),
    fetchViews('?start=month'),
    fetchViews('?start=year')
]);

type ManagementCard = {
    href: string;
    title: string;
    description: string;
    icon: string;
    accent: keyof typeof accentClasses;
    wide?: boolean;
};

const managementCards = [
    {
        href: '/admin/projects',
        title: 'Project Portfolio',
        description: 'Create, refine, or remove showcase project entries synced directly to your production portfolio pipeline.',
        icon: 'heroicons:code-bracket-square',
        accent: 'cyan'
    },
    {
        href: '/admin/team',
        title: 'Team Roster',
        description: 'Update company team profiles, positions, and operational details displayed across public layout sections.',
        icon: 'heroicons:user-group',
        accent: 'purple'
    },
    {
        href: '/admin/images',
        title: 'Media Library',
        description: 'Upload dynamic showcase images, manage descriptive alt data, and maintain global media asset links.',
        icon: 'heroicons:photo',
        accent: 'amber',
        wide: true
    }
] satisfies readonly ManagementCard[];

const accentClasses = {
    cyan: {
        card: 'hover:border-cyan-500/30',
        icon: 'bg-cyan-500/10 border-cyan-500/20 text-cyan-400',
        title: 'group-hover:text-cyan-400',
        arrow: 'group-hover:text-cyan-400'
    },
    purple: {
        card: 'hover:border-purple-500/40',
        icon: 'bg-purple-500/10 border-purple-500/20 text-purple-400',
        title: 'group-hover:text-purple-400',
        arrow: 'group-hover:text-purple-400'
    },
    amber: {
        card: 'hover:border-amber-500/30',
        icon: 'bg-amber-500/10 border-amber-500/20 text-amber-400',
        title: 'group-hover:text-amber-400',
        arrow: 'group-hover:text-amber-400'
    }
} as const;
---

<Layout title="Admin Dashboard">
    <section class="mx-auto max-w-5xl px-4 py-12 text-white">
        <header class="mb-10 space-y-2">
            <h1
                class="bg-gradient-to-r from-purple-400 via-indigo-400 to-cyan-400
                    bg-clip-text font-header text-3xl font-bold tracking-tight
                    text-transparent"
            >
                System Control Panel
            </h1>

            <p class="font-body text-sm font-medium text-gray-400">Welcome back. Select an administrative node below to manage live platform datasets.</p>
        </header>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {
                managementCards.map((card) => {
                    const accent = accentClasses[card.accent];

                    return (
                        <a
                            href={card.href}
                            class:list={[
                                `group block rounded-2xl border border-white/5
                                bg-[#121214] p-6 shadow-xl
                                transition-all duration-300
                                hover:-translate-y-1 hover:bg-white/[0.01]`,
                                accent.card,
                                card.wide && 'md:col-span-2'
                            ]}
                        >
                            <div class="flex items-start justify-between gap-5">
                                <div class="space-y-4">
                                    <div
                                        class:list={[
                                            `flex h-12 w-12 items-center justify-center
                                            rounded-xl border
                                            transition-transform duration-300
                                            group-hover:scale-105`,
                                            accent.icon
                                        ]}
                                    >
                                        <Icon name={card.icon} class="h-6 w-6" />
                                    </div>

                                    <div class="space-y-1">
                                        <h2
                                            class:list={[
                                                `font-body text-lg font-bold text-white
                                                transition-colors`,
                                                accent.title
                                            ]}
                                        >
                                            {card.title}
                                        </h2>

                                        <p class="font-body text-xs leading-relaxed text-gray-400">{card.description}</p>
                                    </div>
                                </div>

                                <Icon
                                    name="heroicons:arrow-right"
                                    class:list={[
                                        `mt-1 h-5 w-5 shrink-0 text-gray-600
                                        transition-all duration-300
                                        group-hover:translate-x-1`,
                                        accent.arrow
                                    ]}
                                />
                            </div>
                        </a>
                    );
                })
            }

            <section
                class="group md:col-span-2 rounded-2xl border border-white/5
                    bg-[#121214] p-6 shadow-xl
                    transition-all duration-300
                    hover:border-complementary/40"
            >
                <div class="mb-6 flex items-start justify-between gap-5">
                    <div class="space-y-4">
                        <div
                            class="flex h-12 w-12 items-center justify-center
                                rounded-xl border border-primary/30
                                bg-primary/20 text-complementary
                                transition-transform duration-300
                                group-hover:scale-105"
                        >
                            <Icon name="heroicons:chart-bar-square" class="h-6 w-6" />
                        </div>

                        <div class="space-y-1">
                            <div class="flex items-center gap-2">
                                <h2
                                    class="font-body text-lg font-bold text-white
                                        transition-colors
                                        group-hover:text-complementary"
                                >
                                    Traffic & Analytics
                                </h2>

                                <span class="relative flex h-2 w-2">
                                    <span
                                        class="absolute inline-flex h-full w-full
                                            animate-ping rounded-full
                                            bg-emerald-400 opacity-75"
                                    ></span>

                                    <span class="relative inline-flex h-2 w-2
                                            rounded-full bg-emerald-500"></span>
                                </span>
                            </div>

                            <p class="font-body text-xs leading-relaxed text-gray-400">
                                Live user interaction monitoring. Open the analytics dashboard to inspect traffic maps, click pathways, and platform statistics.
                            </p>
                        </div>
                    </div>

                    <a
                        href={`https://${GOATCOUNTER_SUBDOMAIN}.goatcounter.com`}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Open GoatCounter analytics"
                        class="pt-1 text-gray-600 transition-colors
                            hover:text-complementary"
                    >
                        <Icon name="heroicons:arrow-top-right-on-square" class="h-5 w-5 transition-transform
                                hover:scale-110" />
                    </a>
                </div>

                <dl class="mt-4 grid grid-cols-2 gap-4
                        border-t border-white/[0.03] pt-4
                        sm:grid-cols-4">
                    <div class="rounded-xl border border-white/5 bg-black/20 p-3">
                        <dt class="font-body text-[10px] font-semibold uppercase tracking-wider text-gray-500">Today</dt>

                        <dd class="mt-0.5 font-body text-xl font-bold text-white">
                            {viewsToday}
                        </dd>
                    </div>

                    <div class="rounded-xl border border-white/5 bg-black/20 p-3">
                        <dt class="font-body text-[10px] font-semibold uppercase tracking-wider text-gray-500">This Week</dt>

                        <dd class="mt-0.5 font-body text-xl font-bold text-indigo-400">
                            {viewsWeek}
                        </dd>
                    </div>

                    <div class="rounded-xl border border-white/5 bg-black/20 p-3">
                        <dt class="font-body text-[10px] font-semibold uppercase tracking-wider text-gray-500">This Month</dt>

                        <dd class="mt-0.5 font-body text-xl font-bold text-complementary">
                            {viewsMonth}
                        </dd>
                    </div>

                    <div class="rounded-xl border border-white/5 bg-black/20 p-3">
                        <dt class="font-body text-[10px] font-semibold uppercase tracking-wider text-gray-500">This Year</dt>

                        <dd class="mt-0.5 font-body text-xl font-bold text-cyan-400">
                            {viewsYear}
                        </dd>
                    </div>
                </dl>
            </section>
        </div>
    </section>
</Layout>
