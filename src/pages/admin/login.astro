---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import type { LoginResponse } from '@data/AuthData';

const API_BASE_URL = import.meta.env.AZURE_API_URL;

let errorMessage = '';
let usernameValue = '';

if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const username = formData.get('username')?.toString().trim();
        const password = formData.get('password')?.toString();

        if (username) usernameValue = username;

        if (!username || !password) {
            errorMessage = 'Please enter both username and password.';
        } else {
            const response = await fetch(`${API_BASE_URL}/api/auth/login`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password })
            });

            if (response.ok) {
                //Strictly type the response mapping to C# LoginResponse DTO
                const data = (await response.json()) as LoginResponse;

                //Extract the token safely
                const token = data.token;

                //Place it in a secure HttpOnly cookie wrapper
                Astro.cookies.set('admin_token', token, {
                    path: '/',
                    httpOnly: true,
                    secure: true,
                    sameSite: 'strict',
                    maxAge: 60 * 60 * 2 //2 hour expiration
                });

                return Astro.redirect('/admin/dashboard');
            } else if (response.status === 401) {
                //Catches your controller's direct return Unauthorized("...") responses
                errorMessage = 'Invalid username or password.';
            } else {
                errorMessage = 'An error occurred on the server. Please try again.';
            }
        }
    } catch (error) {
        console.error('Login submission error:', error);
        errorMessage = 'Unable to connect to the authentication service.';
    }
}
---

<Layout title="Monarch Media LLC | Admin Login">
    <div class="px-4 relative z-10 max-w-md mx-auto py-24 min-h-[80svh] flex flex-col justify-center">
        <div class="bg-[#121214] border border-white/5 rounded-2xl p-8 shadow-2xl shadow-[#451a6b]/5">
            <div class="text-center mb-6">
                <h1 class="font-header text-3xl font-bold bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                    Admin Portal
                </h1>
                <p class="text-gray-400 font-body text-xs uppercase tracking-wider pt-1">Sign in to manage portfolio assets</p>
            </div>

            {
                errorMessage && (
                    <div class="mb-4 bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-center">
                        <p class="text-red-400 font-body text-sm font-medium">{errorMessage}</p>
                    </div>
                )
            }

            <form method="POST" class="space-y-4">
                <div>
                    <label for="username" class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2"> Username </label>
                    <input
                        type="text"
                        id="username"
                        name="username"
                        value={usernameValue}
                        required
                        class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white font-body text-sm focus:outline-none focus:border-[#451a6b]/60 transition-colors"
                        autocomplete="username"
                    />
                </div>

                <div>
                    <label for="password" class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2"> Password </label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        required
                        class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-white font-body text-sm focus:outline-none focus:border-[#451a6b]/60 transition-colors"
                        autocomplete="current-password"
                    />
                </div>

                <div class="pt-2">
                    <button
                        type="submit"
                        class="w-full bg-gradient-to-r from-[#451a6b] to-[#63289a] hover:from-[#52207e] hover:to-[#7430b2] text-white font-body font-semibold text-sm uppercase tracking-wider py-3 rounded-xl transition-all shadow-md active:scale-[0.99]"
                    >
                        Login
                    </button>
                </div>
            </form>
        </div>
    </div>
</Layout>
