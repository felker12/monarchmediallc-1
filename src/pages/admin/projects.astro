---
// src/pages/admin/projects.astro
import Layout from '@layouts/Layout.astro';
import AddProjectForm from '@components/admin/AddProjectForm.astro';
import ProjectList from '@components/admin/ProjectList.astro';
import ProjectForm from '@components/admin/ProjectForm.astro';
import type { ProjectItem } from '@data/ProjectData';

export const prerender = false;

const token = Astro.cookies.get('admin_token')?.value;
if (!token) {
    return Astro.redirect('/admin/login');
}

const successMessage = Astro.url.searchParams.get('success') || '';
const errorMessage = Astro.url.searchParams.get('error') || '';

//Check Astro's meta environment or fall back to standard process environments for server contexts
const API_BASE_URL = import.meta.env.AZURE_API_URL || 'https://your-dotnet-app-service.azurewebsites.net';

let projects: ProjectItem[] = [];
let availableImages: any[] = [];

try {
    //Fetch Projects safely
    const response = await fetch(`${API_BASE_URL}/api/admin/projects`, {
        headers: { Authorization: `Bearer ${token}` }
    });
    if (response.ok) {
        projects = await response.json();
    } else {
        console.error(`Backend project fetch returned status code: ${response.status}`);
    }

    //Fetch Site Images Library safely
    const imagesResponse = await fetch(`${API_BASE_URL}/api/admin/images`, {
        headers: { Authorization: `Bearer ${token}` }
    });
    if (imagesResponse.ok) {
        availableImages = await imagesResponse.json();
    } else {
        console.error(`Backend images fetch returned status code: ${imagesResponse.status}`);
    }
} catch (e) {
    console.error('Data pull exception handled safely without crashing route:', e);
}

const editTargetId = Astro.url.searchParams.get('edit');
const projectToEdit = editTargetId ? projects.find((p) => p.id === parseInt(editTargetId, 10)) : null;
---

<Layout title="Monarch Media | Manage Projects">
    <main class="max-w-4xl mx-auto px-4 py-12 text-white space-y-12">
        <div>
            <h1 class="font-header text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent tracking-tight">Project Manager</h1>
            <p class="text-gray-400 font-body text-sm mt-1">Create and manage portfolio showcase assets.</p>
        </div>

        {
            successMessage && !projectToEdit && (
                <div class="bg-emerald-500/10 border border-emerald-500/20 rounded-xl p-4 text-emerald-400 font-body text-sm font-medium text-center">
                    {successMessage}
                </div>
            )
        }
        {
            errorMessage && !projectToEdit && (
                <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-red-400 font-body text-sm font-medium text-center">{errorMessage}</div>
            )
        }

        <AddProjectForm images={availableImages} />

        <ProjectList projects={projects} />

        <ProjectForm project={projectToEdit} images={availableImages} />
    </main>
</Layout>
