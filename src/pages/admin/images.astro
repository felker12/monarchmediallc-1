---
export const prerender = false;

import { Icon } from 'astro-icon/components';
import Layout from '@layouts/Layout.astro';
import EditImageModal from '@components/admin/EditImageModal.astro';
import type { SiteImageItem } from '@data/ImageData';
import { fetchApi } from '@lib/api';

const token = Astro.cookies.get('admin_token')?.value;

if (!token) {
    return Astro.redirect('/admin/login');
}

let images: SiteImageItem[] = [];
let errorMessage = '';

try {
    images = await fetchApi<SiteImageItem[]>('/api/admin/images', {
        headers: {
            Authorization: `Bearer ${token}`
        }
    });
} catch (error) {
    console.error('Failed to load image library:', error);

    errorMessage = error instanceof Error ? error.message : 'Unable to load the media library.';
}
---

<Layout title="Media Library">
    <main class="max-w-5xl mx-auto px-4 py-12 text-white space-y-12">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="font-header text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                    Media Library
                </h1>

                <p class="text-gray-400 font-body text-sm mt-1">Upload and manage image assets for portfolio projects and team members.</p>
            </div>

            <button
                type="button"
                id="open-upload-modal-btn"
                class="bg-indigo-600 hover:bg-indigo-500 font-body font-semibold text-xs uppercase tracking-wider text-white px-5 py-3 rounded-xl transition-all shadow-md active:scale-[0.98] self-start sm:self-center cursor-pointer"
            >
                Upload Image
            </button>
        </div>

        {
            errorMessage && (
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl font-body text-sm text-center font-medium">{errorMessage}</div>
            )
        }

        {
            images.length === 0 && !errorMessage ? (
                <div class="bg-[#121214] border border-white/5 rounded-2xl p-12 text-center shadow-xl">
                    <p class="text-gray-500 font-body text-sm italic">No image records found in the media library.</p>
                </div>
            ) : (
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
                    {images.map((image) => (
                        <article class="group relative bg-[#121214] border border-white/5 rounded-2xl overflow-hidden shadow-xl hover:border-white/10 transition-all duration-200 flex flex-col justify-between">
                            <div>
                                <div class="aspect-video w-full bg-[#1a1a1e] overflow-hidden relative border-b border-white/5">
                                    <img
                                        src={image.publicUrl}
                                        alt={image.altText || image.fileName}
                                        loading="lazy"
                                        decoding="async"
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                                    />

                                    <div class="absolute top-3 right-3 flex items-center gap-2 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-all duration-150">
                                        <button
                                            type="button"
                                            data-edit-id={image.id}
                                            data-edit-url={image.publicUrl}
                                            data-edit-alt={image.altText || ''}
                                            class="edit-image-btn p-2 bg-black/70 hover:bg-indigo-600/90 text-gray-300 hover:text-white rounded-xl border border-white/10 backdrop-blur-sm shadow-md cursor-pointer"
                                            title="Edit alt text"
                                            aria-label={`Edit metadata for ${image.fileName}`}
                                        >
                                            <Icon name="heroicons:pencil-square" class="h-4 w-4" />
                                        </button>

                                        <button
                                            type="button"
                                            data-delete-id={image.id}
                                            class="delete-image-btn p-2 bg-black/70 hover:bg-red-600/90 disabled:opacity-60 disabled:cursor-not-allowed text-gray-300 hover:text-white rounded-xl border border-white/10 backdrop-blur-sm shadow-md cursor-pointer"
                                            title="Delete asset"
                                            aria-label={`Delete ${image.fileName}`}
                                        >
                                            <Icon name="heroicons:trash" class="h-4 w-4" />
                                        </button>
                                    </div>
                                </div>

                                <div class="p-4 space-y-1">
                                    <p class="text-xs font-body font-bold text-gray-200 truncate" title={image.fileName}>
                                        {image.fileName}
                                    </p>

                                    <p class="text-[11px] font-body text-gray-400 line-clamp-2 min-h-[2rem]">
                                        {image.altText || <span class="text-gray-600 italic">No description provided</span>}
                                    </p>
                                </div>
                            </div>

                            <div class="px-4 pb-4">
                                <p class="text-[10px] font-mono text-gray-500 pt-2 border-t border-white/5">
                                    DB pointer:
                                    <span class="text-indigo-400 font-semibold ml-1">#{image.id}</span>
                                </p>
                            </div>
                        </article>
                    ))}
                </div>
            )
        }
    </main>

    <dialog id="upload-modal" class="backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-transparent w-full max-w-md p-4 focus:outline-none">
        <section class="bg-[#121214] border border-white/10 rounded-2xl p-6 shadow-2xl text-white">
            <h2 class="font-header text-xl font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent mb-5">
                Upload New Image Asset
            </h2>

            <form id="upload-form" class="space-y-5">
                <div>
                    <label for="upload-file" class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2"> Select File * </label>

                    <input
                        id="upload-file"
                        type="file"
                        name="file"
                        accept="image/jpeg,image/png,image/webp,image/svg+xml"
                        required
                        class="w-full text-sm text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-white/5 file:text-white hover:file:bg-white/10 file:cursor-pointer bg-[#1a1a1e] p-2.5 rounded-xl border border-white/5 focus:outline-none"
                    />
                </div>

                <div>
                    <label for="upload-alt-text" class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2"> Alt Text </label>

                    <input
                        id="upload-alt-text"
                        type="text"
                        name="altText"
                        placeholder="e.g. Website design interface for client"
                        class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-500/60 text-white font-body"
                    />
                </div>

                <div class="flex justify-end gap-3 pt-3 border-t border-white/5">
                    <button
                        type="button"
                        id="close-upload-modal-btn"
                        class="px-4 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-white/5 hover:bg-white/10 transition-colors border border-white/5 cursor-pointer"
                    >
                        Cancel
                    </button>

                    <button
                        type="submit"
                        id="upload-submit-btn"
                        class="px-5 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-indigo-600 hover:bg-indigo-500 disabled:opacity-60 disabled:cursor-not-allowed text-white transition-colors shadow-md cursor-pointer"
                    >
                        Upload Asset
                    </button>
                </div>
            </form>
        </section>
    </dialog>

    <EditImageModal />
</Layout>

<script is:inline>
    {
        const uploadModal = document.getElementById('upload-modal');

        const openUploadButton = document.getElementById('open-upload-modal-btn');

        const closeUploadButton = document.getElementById('close-upload-modal-btn');

        const uploadForm = document.getElementById('upload-form');

        const uploadSubmitButton = document.getElementById('upload-submit-btn');

        openUploadButton?.addEventListener('click', () => {
            if (uploadModal instanceof HTMLDialogElement) {
                uploadModal.showModal();
            }
        });

        closeUploadButton?.addEventListener('click', () => {
            if (uploadModal instanceof HTMLDialogElement) {
                uploadModal.close();
            }
        });

        uploadForm?.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (!(uploadForm instanceof HTMLFormElement)) {
                return;
            }

            if (uploadSubmitButton instanceof HTMLButtonElement) {
                uploadSubmitButton.disabled = true;
                uploadSubmitButton.textContent = 'Uploading...';
            }

            const formData = new FormData(uploadForm);

            try {
                const response = await fetch('/api/admin/images/upload', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const message = await response.text();

                    alert(`Upload failed: ${message || response.statusText}`);

                    if (uploadSubmitButton instanceof HTMLButtonElement) {
                        uploadSubmitButton.disabled = false;

                        uploadSubmitButton.textContent = 'Upload Asset';
                    }

                    return;
                }

                window.location.reload();
            } catch (error) {
                console.error('Image upload failed:', error);

                alert('Network error while uploading the image.');

                if (uploadSubmitButton instanceof HTMLButtonElement) {
                    uploadSubmitButton.disabled = false;

                    uploadSubmitButton.textContent = 'Upload Asset';
                }
            }
        });

        document.addEventListener('click', async (event) => {
            const target = event.target;

            if (!(target instanceof Element)) {
                return;
            }

            const deleteButton = target.closest('.delete-image-btn');

            if (!(deleteButton instanceof HTMLButtonElement)) {
                return;
            }

            const imageId = deleteButton.dataset.deleteId;

            if (!imageId) {
                alert('The image ID is missing.');
                return;
            }

            const confirmed = window.confirm('Are you sure you want to permanently delete this media asset? This action cannot be undone.');

            if (!confirmed) {
                return;
            }

            deleteButton.disabled = true;

            try {
                const response = await fetch(`/api/admin/images/${imageId}`, {
                    method: 'DELETE'
                });

                if (!response.ok) {
                    const responseText = await response.text();

                    let errorMessage = responseText || 'Could not delete the image.';

                    try {
                        const errorData = JSON.parse(responseText);

                        errorMessage = errorData.error ?? errorData.message ?? responseText;
                    } catch {
                        // Keep plain-text response.
                    }

                    alert(errorMessage);
                    deleteButton.disabled = false;
                    return;
                }

                window.location.reload();
            } catch (error) {
                console.error('Image deletion failed:', error);

                alert('Network error while deleting the image.');

                deleteButton.disabled = false;
            }
        });
    }
</script>
