---
export const prerender = false;
import Layout from '@layouts/Layout.astro';
import EditImageModal from '@components/admin/EditImageModal.astro';

// Enforce strict session validation
const token = Astro.cookies.get('admin_token')?.value;
if (!token) {
    return Astro.redirect('/admin/login');
}

const API_URL = import.meta.env.AZURE_API_URL;
let images = [];
let errorMessage = '';

try {
    const response = await fetch(`${API_URL}/api/admin/images`, {
        headers: { Authorization: `Bearer ${token}` }
    });
    if (response.ok) {
        images = await response.json();
    } else {
        errorMessage = 'Failed to load assets from the gallery database.';
    }
} catch (e) {
    errorMessage = 'Could not establish connection to the Azure asset server.';
}
---

<Layout title="Monarch Media | Media Library">
    <main class="max-w-5xl mx-auto px-4 py-12 text-white space-y-12">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="font-header text-3xl font-bold bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent tracking-tight">
                    Media Library
                </h1>
                <p class="text-gray-400 font-body text-sm mt-1">Upload and manage image assets for portfolio projects.</p>
            </div>

            <button
                onclick="document.getElementById('upload-modal').showModal()"
                class="bg-indigo-600 hover:bg-indigo-500 font-body font-semibold text-xs uppercase tracking-wider text-white px-5 py-3 rounded-xl transition-all shadow-md active:scale-[0.98] self-start sm:self-center"
            >
                Upload Image
            </button>
        </div>

        {
            errorMessage && (
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl font-body text-sm text-center font-medium">{errorMessage}</div>
            )
        }

        {
            images.length === 0 && !errorMessage ? (
                <div class="bg-[#121214] border border-white/5 rounded-2xl p-12 text-center shadow-xl">
                    <p class="text-gray-500 font-body text-sm italic">No image records found in the Supabase Asset Bucket.</p>
                </div>
            ) : (
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
                    {images.map((img: any) => (
                        <div class="group relative bg-[#121214] border border-white/5 rounded-2xl overflow-hidden shadow-xl hover:border-white/10 transition-all duration-200 flex flex-col justify-between">
                            <div>
                                <div class="aspect-video w-full bg-[#1a1a1e] overflow-hidden relative border-b border-white/5">
                                    <img
                                        src={img.publicUrl}
                                        alt={img.altText || img.fileName}
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                                    />

                                    <div class="absolute top-3 right-3 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-150">
                                        <button
                                            data-edit-id={img.id}
                                            data-edit-url={img.publicUrl}
                                            data-edit-alt={img.altText || ''}
                                            class="edit-image-btn p-2 bg-black/70 hover:bg-indigo-600/90 text-gray-300 hover:text-white rounded-xl border border-white/10 backdrop-blur-sm shadow-md cursor-pointer"
                                            title="Edit Alt Text"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke-width="2"
                                                stroke="currentColor"
                                                class="w-4 h-4"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"
                                                />
                                            </svg>
                                        </button>
                                        <button
                                            data-delete-id={img.id}
                                            class="delete-image-btn p-2 bg-black/70 hover:bg-red-600/90 text-gray-300 hover:text-white rounded-xl border border-white/10 backdrop-blur-sm shadow-md cursor-pointer"
                                            title="Delete Asset"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke-width="2"
                                                stroke="currentColor"
                                                class="w-4 h-4"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"
                                                />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                                <div class="p-4 space-y-1">
                                    <p class="text-xs font-body font-bold text-gray-200 truncate" title={img.fileName}>
                                        {img.fileName}
                                    </p>
                                    <p class="text-[11px] font-body text-gray-400 line-clamp-2 min-h-[2rem]">
                                        {img.altText || <span class="text-gray-600 italic">No description provided</span>}
                                    </p>
                                </div>
                            </div>
                            <div class="px-4 pb-4">
                                <p class="text-[10px] font-mono text-gray-500 pt-2 border-t border-white/5">
                                    Db Pointer Key: <span class="text-indigo-400 font-semibold">#{img.id}</span>
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            )
        }
    </main>

    <dialog id="upload-modal" class="backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-transparent w-full max-w-md p-4 focus:outline-none">
        <section class="bg-[#121214] border border-white/10 rounded-2xl p-6 shadow-2xl text-white">
            <h3 class="font-header text-xl font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent mb-5">
                Upload New Image Asset
            </h3>

            <form id="upload-form" class="space-y-5">
                <div>
                    <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Select File *</label>
                    <input
                        type="file"
                        name="file"
                        accept="image/*"
                        required
                        class="w-full text-sm text-gray-400 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-white/5 file:text-white hover:file:bg-white/10 file:cursor-pointer bg-[#1a1a1e] p-2.5 rounded-xl border border-white/5 focus:outline-none"
                    />
                </div>
                <div>
                    <label class="block text-gray-400 font-body text-xs font-semibold uppercase tracking-wider mb-2">Alt Text</label>
                    <input
                        type="text"
                        name="altText"
                        placeholder="e.g. Website design interface for client"
                        class="w-full bg-[#1a1a1e] border border-white/5 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-purple-500/60 text-white font-body"
                    />
                </div>
                <div class="flex justify-end gap-3 pt-3 border-t border-white/5">
                    <button
                        type="button"
                        onclick="document.getElementById('upload-modal').close()"
                        class="px-4 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-white/5 hover:bg-white/10 transition-colors border border-white/5"
                    >
                        Cancel
                    </button>
                    <button
                        type="submit"
                        class="px-5 py-2.5 rounded-xl text-xs font-body font-semibold uppercase tracking-wider bg-indigo-600 hover:bg-indigo-500 text-white transition-colors shadow-md"
                    >
                        Upload Asset
                    </button>
                </div>
            </form>
        </section>
    </dialog>

    <EditImageModal API_URL={API_URL} token={token} />
</Layout>

<script is:inline define:vars={{ API_URL, token }}>
    // Handle AJAX Upload Interception
    document.getElementById('upload-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = e.target.querySelector('button[type="submit"]');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerText = 'Uploading...';
        }

        const formData = new FormData(e.target);

        try {
            const res = await fetch(`${API_URL}/api/admin/images/upload`, {
                method: 'POST',
                headers: { Authorization: `Bearer ${token}` },
                body: formData
            });
            if (res.ok) {
                window.location.reload();
            } else {
                const text = await res.text();
                alert(`Upload failed: ${text || res.statusText}`);
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Upload Asset';
                }
            }
        } catch (err) {
            alert('Network error trying to upload file assets.');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerText = 'Upload Asset';
            }
        }
    });

    // Handle AJAX Asset Removal
    document.querySelectorAll('.delete-image-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
            if (!confirm('Are you sure you want to permanently delete this media asset? This action cannot be undone.')) return;
            const id = btn.getAttribute('data-delete-id');

            try {
                const res = await fetch(`${API_URL}/api/admin/images/${id}`, {
                    method: 'DELETE',
                    headers: { Authorization: `Bearer ${token}` }
                });

                if (res.status === 409) {
                    alert('Conflict Error: This image is currently assigned to one or more live portfolio projects and cannot be removed.');
                    return;
                }

                if (res.ok) {
                    window.location.reload();
                } else {
                    alert('Could not remove file record from server.');
                }
            } catch (err) {
                alert('Network error trying to contact the deletion service.');
            }
        });
    });
</script>
